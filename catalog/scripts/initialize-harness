#!/usr/bin/env python3
"""
initialize-harness — bootstrap a project's runtime from the plugin catalog.

This is the ONE globally-registered plugin command. Everything else (the
microskill/workflow/sync-harness dispatchers, per-component shims) is materialized
into the project's .claude/ here, which is what keeps them hidden until a project
is initialized. It:

  1. Seeds harness/harness.yaml from the catalog's base-tagged components (only if
     absent — an existing manifest is used as-is, never overwritten).
  2. Materializes the ENGINE (scripts, dispatcher skills, agents, engine command
     shims) from the plugin catalog into .claude/.
  3. Materializes every `source: plugin` component listed in harness.yaml into
     .claude/ (+ generated shim), honoring the profiles selection.
  4. Records everything in .claude/.harness-state.json: plugin components tagged
     source:plugin, plus an `engine` block. `source: custom` components are owned by
     harness-sync and are preserved here untouched.

Plugin provenance is owned HERE. harness-sync NEVER touches source:plugin entries;
this command NEVER touches source:custom entries. Re-running is an explicit re-pull
from the (possibly updated) catalog.

Lifecycle extras:
  - Provenance stamping: on --apply every added/updated source:plugin ledger entry is
    stamped with the catalog's plugin version (.claude-plugin/plugin.json beside catalog/),
    so plans report version transitions ("0.8.0 -> 0.9.0") instead of bare hash pairs.
  - Version pins are HOLDs: a manifest entry's `version:` field pins that component. While
    the pin differs from the catalog's version, the deployed bytes stay put and the pending
    change surfaces in every plan (action "hold") until the pin moves.
  - --eject <name>: transfer a source:plugin component to source:custom ownership — vendor
    the catalog bytes into harness/, rewrite the entry's harness.yaml source line in place,
    and atomically flip the ledger entry. tree_hash is location-independent, so the next
    harness-sync plans a noop when deployed bytes match the catalog.

Catalog root resolves to ${CLAUDE_PLUGIN_ROOT}/catalog (installed plugin) or
<repo>/catalog (in-repo dogfood). Project root is the cwd (or --project-root).

Usage:
  initialize-harness [--plan | --apply] [--adopt-base] [--eject <name>]
                     [--project-root <dir>] [--catalog <dir>]
                     [--harness-root <dir>] [--harness-yaml <file>]
                     [--state <file>] [--deploy-root <dir>]

Stdout: JSON result. Exit codes: 0 clean · 1 block (conflict/error/bad input) · 2 env/script error.
"""

import argparse
import hashlib
import importlib.machinery
import importlib.util
import json
import os
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print(json.dumps({"error": "PyYAML not installed. pip3 install pyyaml"}))
    sys.exit(2)

try:
    from jsonschema import Draft202012Validator
except ImportError:
    print(json.dumps({"error": "jsonschema not installed. pip3 install jsonschema"}))
    sys.exit(2)

SCRIPT = Path(__file__).resolve()
PROJECT_ROOT_DEFAULT = SCRIPT.parents[2]
# Plugin root for catalog discovery: ${CLAUDE_PLUGIN_ROOT}/catalog (installed) or <repo>/catalog.
PLUGIN_ROOT = Path(os.environ.get("CLAUDE_PLUGIN_ROOT", PROJECT_ROOT_DEFAULT))


def _templates_root(script):
    """Locate the templates/ tree (schemas + component templates). Prefer the materialized
    runtime copy, then an explicit ${CLAUDE_PLUGIN_ROOT}, then the in-repo dogfood source."""
    proj = script.parents[2]
    cands = [proj / ".claude" / "templates"]
    env = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if env:
        cands.append(Path(env) / "templates")
    cands.append(proj / "templates")
    return next((c for c in cands if c.is_dir()), cands[0])


SCHEMA_PATH = _templates_root(SCRIPT) / "references" / "harness-schema.json"
HARNESS_SYNC = SCRIPT.parent / "harness-sync"

# Reuse the harness-sync engine (extension-less file → SourceFileLoader). harness-sync
# in turn loads resolve-microskill; importing it only defines functions (its argparse is
# guarded by __main__), so this is side-effect-free.
_loader = importlib.machinery.SourceFileLoader("harness_sync", str(HARNESS_SYNC))
_spec = importlib.util.spec_from_loader("harness_sync", _loader)
_hs = importlib.util.module_from_spec(_spec)
_loader.exec_module(_hs)

# Engine subtrees materialized verbatim into .claude/, and paths to skip. initialize-harness
# itself + the dev tests stay plugin-resident; the initialize-harness dispatcher is never
# materialized (it remains the plugin's sole global entry point).
ENGINE_SUBDIRS = ["scripts", "skills", "agents", "commands"]
ENGINE_SKIP_PARTS = {"initialize-harness", "tests", "__pycache__"}


def die(msg, code=2, **extra):
    payload = {"error": msg}
    payload.update(extra)
    print(json.dumps(payload, indent=2))
    sys.exit(code)


def read_base(src_dir, kind):
    """True if the component is tagged base (MICROSKILL.md frontmatter base:true for
    microskills, top-level base:true for workflows)."""
    if kind == "microskill":
        try:
            meta_raw = _hs.split_frontmatter((src_dir / "MICROSKILL.md").read_text())[0]
        except OSError:
            return False
        if not meta_raw:
            return False
        try:
            meta = yaml.safe_load(meta_raw) or {}
        except yaml.YAMLError:
            return False
    else:
        try:
            meta = yaml.safe_load((src_dir / "WORKFLOW.yaml").read_text()) or {}
        except (OSError, yaml.YAMLError):
            return False
    return bool(isinstance(meta, dict) and meta.get("base"))


def catalog_names(catalog, kind):
    d = catalog / _hs.KIND_DIR[kind]
    if not d.is_dir():
        return []
    return sorted(p.name for p in d.iterdir() if p.is_dir() and not p.name.startswith("."))


def _list_key_for(kind):
    """'microskill' -> 'microskills', 'workflow' -> 'workflows'."""
    return {k: lk for lk, k in _hs.LIST_KIND.items()}[kind]


def classify_import(imp, catalog):
    """Resolve an imports[] entry to (kind, name), or (None, name) if it resolves to nothing.
    Grammar: 'microskills/<name>' -> microskill (a leaf); 'workflow-defs/<name>' -> workflow;
    a bare '<name>' -> workflow by convention. The prefix is authoritative when present; a bare
    name is classified by catalog existence (workflow first), so the convention can be verified."""
    name = imp.split("/", 1)[1] if "/" in imp else imp
    if imp.startswith("microskills/"):
        return ("microskill", name) if (catalog / "microskills" / name).is_dir() else (None, name)
    if imp.startswith("workflow-defs/"):
        return ("workflow", name) if (catalog / "workflow-defs" / name).is_dir() else (None, name)
    if (catalog / "workflow-defs" / name).is_dir():
        return "workflow", name
    if (catalog / "microskills" / name).is_dir():
        return "microskill", name
    return None, name


def workflow_imports(catalog, name):
    """The raw string imports[] of a workflow's WORKFLOW.yaml ([] if absent/unreadable)."""
    try:
        doc = yaml.safe_load((catalog / "workflow-defs" / name / "WORKFLOW.yaml").read_text()) or {}
    except (OSError, yaml.YAMLError):
        return []
    return [i for i in (doc.get("imports") or []) if isinstance(i, str)]


def walk_closure(roots, catalog):
    """Transitive imports-closure of `roots` (list of (kind, name)).
    Returns (derived, unresolved):
      derived    -- {(kind, name): root_name} for every DERIVED component reachable from a
                    root (roots themselves excluded). root_name = the lexicographically-smallest
                    root that reaches it (roots iterated ascending, first writer wins).
      unresolved -- sorted unique import strings that resolve to no catalog component.
    Microskills are leaves (no recursion); workflows recurse. A global `seen` set guards
    against cycles and redundant re-expansion."""
    derived, unresolved, seen = {}, [], set()
    rootset = {(k, n) for k, n in roots}
    for rkind, rname in sorted(roots):
        if rkind != "workflow":
            continue  # microskill roots are leaves
        stack = [rname]
        while stack:
            wf = stack.pop()
            if wf in seen:
                continue
            seen.add(wf)
            for imp in workflow_imports(catalog, wf):
                kind, cname = classify_import(imp, catalog)
                if kind is None:
                    unresolved.append(imp)
                    continue
                key = (kind, cname)
                if key not in rootset:
                    derived.setdefault(key, rname)
                if kind == "workflow":
                    stack.append(cname)
    return derived, sorted(set(unresolved))


def seed_manifest(catalog):
    """A v2 harness.yaml dict listing every base-tagged catalog component as source:plugin."""
    m = {"version": 2, "microskills": [], "workflows": []}
    for list_key, kind in _hs.LIST_KIND.items():
        for name in catalog_names(catalog, kind):
            if read_base(catalog / _hs.KIND_DIR[kind] / name, kind):
                m[list_key].append({"name": name, "source": "plugin"})
    return m


def base_drift(manifest, catalog):
    """Base-tagged catalog components absent from the manifest (by name) → [{name, kind}].
    These are base components a fresh seed would include but an existing harness.yaml predates
    (it was generated before they were tagged base in the catalog). Informational unless adopted."""
    listed = {c.get("name") for lk in _hs.LIST_KIND for c in (manifest.get(lk) or [])}
    out = []
    for list_key, kind in _hs.LIST_KIND.items():
        for name in catalog_names(catalog, kind):
            if name in listed:
                continue
            if read_base(catalog / _hs.KIND_DIR[kind] / name, kind):
                out.append({"name": name, "kind": kind})
    return out


def append_plugin_entries(text, additions):
    """Append source:plugin entries to existing harness.yaml text, preserving the header comment
    and every existing entry. `additions` maps list_key -> [name, ...]. A `key: []` empty list is
    converted to block form; a missing list key gets a fresh section appended at EOF."""
    had_trailing_nl = text.endswith("\n")
    lines = text.split("\n")
    if had_trailing_nl and lines and lines[-1] == "":
        lines.pop()

    def header_idx(key):
        for i, ln in enumerate(lines):
            s = ln.rstrip()
            if s == f"{key}:" or s == f"{key}: []":
                return i
        return None

    def block_end(i):
        """Index just after the last indented item line of the list opened at i (skips trailing
        blank lines; stops at the next top-level key or EOF)."""
        j, last = i + 1, i + 1
        while j < len(lines):
            ln = lines[j]
            if ln.strip() == "":
                j += 1
                continue
            if not ln.startswith(" "):
                break
            last = j + 1
            j += 1
        return last

    for key in ("microskills", "workflows"):
        names = additions.get(key)
        if not names:
            continue
        new = []
        for n in names:
            new += [f"  - name: {n}", "    source: plugin"]
        i = header_idx(key)
        if i is None:
            lines += [f"{key}:"] + new
            continue
        if lines[i].rstrip() == f"{key}: []":
            lines[i] = f"{key}:"
        end = block_end(i)
        lines[end:end] = new

    out = "\n".join(lines)
    return out + "\n" if had_trailing_nl else out


def read_plugin_version(catalog):
    """The plugin's declared version (.claude-plugin/plugin.json beside catalog/), or None."""
    pj = catalog.parent / ".claude-plugin" / "plugin.json"
    try:
        v = json.loads(pj.read_text()).get("version")
    except (OSError, json.JSONDecodeError):
        return None
    return v if isinstance(v, str) and v else None


def flip_entry_source(text, list_key, name):
    """In-place line surgery on harness.yaml text: within the <list_key> block, rewrite the
    target entry's `source: plugin` line to `source: custom`, preserving every other byte
    (header comments, sibling entries, the entry's other fields). append_plugin_entries is
    append-only, so eject needs this dedicated rewrite. Returns (new_text, flipped)."""
    had_trailing_nl = text.endswith("\n")
    lines = text.split("\n")
    if had_trailing_nl and lines and lines[-1] == "":
        lines.pop()

    # Collect [start, end) line ranges of the items under the target top-level list key.
    cur_key, item_start, blocks = None, None, []
    for i, ln in enumerate(lines):
        stripped = ln.strip()
        if ln and not ln.startswith(" ") and not stripped.startswith("#"):
            if cur_key == list_key and item_start is not None:
                blocks.append((item_start, i))
                item_start = None
            cur_key = ln.split(":", 1)[0].strip()
            continue
        if cur_key != list_key or not stripped or stripped.startswith("#"):
            continue
        if stripped.startswith("- "):
            if item_start is not None:
                blocks.append((item_start, i))
            item_start = i
    if cur_key == list_key and item_start is not None:
        blocks.append((item_start, len(lines)))

    def field(block, key):
        """(line_index, value) of `key:` within the item block (dash line included), or (None, None)."""
        for j in range(*block):
            t = lines[j].strip()
            if t.startswith("- "):
                t = t[2:].strip()
            if t.startswith(key + ":"):
                return j, t[len(key) + 1:].split("#", 1)[0].strip().strip("'\"")
        return None, None

    for block in blocks:
        if field(block, "name")[1] != name:
            continue
        j, sval = field(block, "source")
        if j is None or sval != "plugin":
            return text, False
        indent = lines[j][: len(lines[j]) - len(lines[j].lstrip())]
        prefix = "- " if lines[j].lstrip().startswith("- ") else ""
        lines[j] = f"{indent}{prefix}source: custom"
        out = "\n".join(lines)
        return (out + "\n" if had_trailing_nl else out), True
    return text, False


def validate_manifest(manifest):
    if not SCHEMA_PATH.exists():
        return
    schema = json.loads(SCHEMA_PATH.read_text())
    errs = sorted(Draft202012Validator(schema).iter_errors(manifest), key=lambda e: list(e.path))
    if errs:
        msgs = ["schema " + ("/".join(str(x) for x in e.path) or "<root>") + ": " + e.message
                for e in errs]
        die("harness.yaml fails schema validation", 1, schema_errors=msgs)


def render_manifest_yaml(m):
    lines = [
        "# Harness manifest (v2) — generated by initialize-harness from the catalog base set.",
        "# source: plugin → materialized from the plugin catalog by initialize-harness.",
        "# source: custom → authored under harness/ and reconciled by harness-sync.",
        "# Schema: templates/references/harness-schema.json",
        f"version: {m['version']}",
    ]
    for list_key in ("microskills", "workflows"):
        items = m.get(list_key) or []
        lines.append(f"{list_key}:" + ("" if items else " []"))
        for c in items:
            lines.append(f"  - name: {c['name']}")
            lines.append(f"    source: {c['source']}")
            prof = c.get("profiles")
            if prof and prof != "*":
                lines.append(f"    profiles: [{', '.join(prof)}]")
    return "\n".join(lines) + "\n"


def engine_outputs(catalog, deploy_root):
    """(src_file, dest_abs) for every engine file materialized into .claude/."""
    out = []
    for sub in ENGINE_SUBDIRS:
        sdir = catalog / sub
        if not sdir.is_dir():
            continue
        for f in sorted(p for p in sdir.rglob("*") if p.is_file()):
            rel = f.relative_to(sdir)
            if set(rel.parts) & ENGINE_SKIP_PARTS or f.suffix == ".pyc":
                continue
            out.append((f, deploy_root / sub / rel))
    # templates/ (schemas + component templates) live at the plugin root, a sibling of
    # catalog/, not under it. The runtime scripts + agents resolve them from .claude/templates,
    # so materialize the whole tree there as part of the engine (tracked/pruned in the ledger).
    tdir = catalog.parent / "templates"
    if tdir.is_dir():
        for f in sorted(p for p in tdir.rglob("*") if p.is_file()):
            if f.suffix == ".pyc":
                continue
            out.append((f, deploy_root / "templates" / f.relative_to(tdir)))
    # Shared prompt snippets ({{snippet:NAME}} includes) are plugin/ENGINE-owned in V1:
    # catalog/workflow-defs/_snippets/ is vendored to .claude/workflow-defs/_snippets/
    # HERE (tracked/pruned in the engine ledger) and only here — _snippets is not a
    # component, never appears in harness.yaml, and harness-sync never touches it.
    sdir = catalog / "workflow-defs" / "_snippets"
    if sdir.is_dir():
        for f in sorted(p for p in sdir.rglob("*") if p.is_file()):
            out.append((f, deploy_root / "workflow-defs" / "_snippets" / f.relative_to(sdir)))
    # Reusable subgraph registry (`subgraph: NAME` node-groups spliced into a host DAG
    # by compile-workflow / validate-workflow) is plugin/ENGINE-owned in V1, exactly
    # like _snippets: catalog/workflow-defs/_subgraphs/<name>/SUBGRAPH.yaml is vendored
    # to .claude/workflow-defs/_subgraphs/ HERE (tracked/pruned in the engine ledger)
    # and only here — _subgraphs is not a component, never appears in harness.yaml, and
    # harness-sync never touches it. rglob enumerates the dir-of-dirs (the nested
    # SUBGRAPH.yaml, and any sibling files), sorted for a stable engine_hash.
    sdir = catalog / "workflow-defs" / "_subgraphs"
    if sdir.is_dir():
        for f in sorted(p for p in sdir.rglob("*") if p.is_file()):
            out.append((f, deploy_root / "workflow-defs" / "_subgraphs" / f.relative_to(sdir)))
    return out


def engine_hash(outputs):
    h = hashlib.sha256()
    for src, dst in sorted(outputs, key=lambda t: str(t[1])):
        h.update(str(dst).encode())
        h.update(b"\0")
        h.update(src.read_bytes())
        h.update(b"\0")
    return "sha256:" + h.hexdigest()


def materialize_engine(outputs, eng_installed, anchor, deploy_root):
    """Copy engine files, preserving exec bits; prune previously-installed engine paths
    no longer produced."""
    new_dests = {dst for _, dst in outputs}
    for rel in (eng_installed or {}).get("installed_paths") or []:
        old = anchor / rel
        if old not in new_dests and old.exists():
            old.unlink()
            _hs.prune_empty(old.parent, deploy_root)
    for src, dst in outputs:
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_bytes(src.read_bytes())
        if os.access(src, os.X_OK):
            dst.chmod(dst.stat().st_mode | 0o111)


def build_plugin_desired(manifest, catalog, anchor):
    """Desired source:plugin components, read from the catalog. (custom entries are
    owned by harness-sync and ignored here.)"""
    desired, errors = {}, []
    for list_key, kind in _hs.LIST_KIND.items():
        for c in manifest.get(list_key) or []:
            if c.get("source") != "plugin":
                continue
            name = c["name"]
            src_dir = catalog / _hs.KIND_DIR[kind] / name
            if not src_dir.is_dir():
                errors.append({"name": name, "reason": f"catalog component not found: {src_dir}"})
                continue
            profiles = _hs.norm_profiles(c.get("profiles"))
            if profiles != "*":
                missing = sorted(set(profiles) - _hs.source_profiles(src_dir))
                if missing:
                    errors.append({"name": name,
                                   "reason": f"selected profiles not in catalog source: {', '.join(missing)}"})
                    continue
            desired[name] = {
                "name": name, "kind": kind, "source": "plugin",
                "profiles": profiles, "src_dir": src_dir,
                "tree_hash": _hs.tree_hash(src_dir),
                "pin": c.get("version"),
            }
    return desired, errors


def run_eject(name, apply, catalog, harness_root, harness_yaml, state_path, anchor):
    """Transfer one source:plugin component to source:custom ownership. Vendors the catalog
    bytes into harness/<kind-dir>/<name>/ (vendor_skip applied — generated artifacts never
    vendored), rewrites the entry's harness.yaml source line in place, and atomically flips
    the ledger entry (tmp+os.replace) — source_hash and installed_paths are preserved, and
    tree_hash is location-independent, so when the deployed copy matches the catalog the
    next harness-sync plans a noop. catalog/ is never edited. Prints JSON and exits."""
    if not harness_yaml.exists():
        die(f"--eject: harness.yaml not found: {harness_yaml}", 1)
    text = harness_yaml.read_text()
    try:
        manifest = yaml.safe_load(text) or {}
    except yaml.YAMLError as e:
        die(f"harness.yaml parse error: {e}", 1)
    validate_manifest(manifest)

    entry = list_key = kind = None
    for lk, k in _hs.LIST_KIND.items():
        for c in manifest.get(lk) or []:
            if c.get("name") == name:
                entry, list_key, kind = c, lk, k
    if entry is None:
        die(f"--eject: '{name}' is not listed in {harness_yaml}", 1)
    if entry.get("source") != "plugin":
        die(f"--eject: '{name}' is source: {entry.get('source')} — only source: plugin "
            f"components can be ejected", 1)

    state = _hs.load_state(state_path)
    components = state.get("components") or {}
    ledger = components.get(name)
    if not ledger:
        die(f"--eject: '{name}' has no ledger entry — run initialize-harness --apply first", 1)
    if ledger.get("source") != "plugin":
        die(f"--eject: ledger entry for '{name}' is source: {ledger.get('source')}, "
            f"not plugin", 1)

    src_dir = catalog / _hs.KIND_DIR[kind] / name
    if not src_dir.is_dir():
        die(f"--eject: catalog component not found: {src_dir}", 1)
    dest_dir = harness_root / _hs.KIND_DIR[kind] / name
    if dest_dir.exists():
        die(f"--eject: destination already exists: {dest_dir} — refusing to overwrite", 1)

    files = []
    for f in sorted(p for p in src_dir.rglob("*") if p.is_file()):
        rel = f.relative_to(src_dir)
        if _hs.vendor_skip(rel):
            continue
        files.append((f, rel))

    new_text, flipped = flip_entry_source(text, list_key, name)
    if not flipped:
        die(f"--eject: could not rewrite 'source: plugin' for '{name}' in {harness_yaml}", 1)

    vendored_hash = _hs.tree_hash(src_dir)
    result = {
        "mode": "apply" if apply else "plan",
        "eject": {
            "name": name, "kind": kind,
            "from": str(src_dir),
            "to": _hs.relto(dest_dir, anchor),
            "files": [rel.as_posix() for _, rel in files],
            "vendored_hash": vendored_hash,
            "ledger_hash": ledger.get("source_hash"),
            # vendored == deployed: the next harness-sync plans a noop. False means the
            # catalog drifted since the last apply — sync will reconcile to the vendored bytes.
            "in_sync": vendored_hash == ledger.get("source_hash"),
            "harness_yaml": _hs.relto(harness_yaml, anchor),
        },
    }
    if not apply:
        print(json.dumps(result, indent=2))
        sys.exit(0)

    for src, rel in files:
        dst = dest_dir / rel
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_bytes(src.read_bytes())
        if os.access(src, os.X_OK):
            dst.chmod(dst.stat().st_mode | 0o111)
    harness_yaml.write_text(new_text)
    # Atomic ownership flip, ledger last: same deployed paths and hash, recast as custom.
    # The plugin provenance stamp is dropped — custom entries are harness-sync's, unstamped.
    new_entry = dict(ledger)
    new_entry["source"] = "custom"
    new_entry.pop("plugin_version", None)
    new_state = dict(state)
    new_state["version"] = _hs.STATE_VERSION
    new_state["components"] = {**components, name: new_entry}
    _hs.write_state_atomic(state_path, new_state)

    result["state_path"] = _hs.relto(state_path, anchor)
    result["state_written"] = True
    print(json.dumps(result, indent=2))
    sys.exit(0)


def main():
    ap = argparse.ArgumentParser(
        description="Bootstrap a project's .claude/ runtime from the plugin catalog.")
    mode = ap.add_mutually_exclusive_group()
    mode.add_argument("--plan", action="store_true", help="Dry-run (default): write nothing.")
    mode.add_argument("--apply", action="store_true", help="Execute the bootstrap.")
    ap.add_argument("--project-root", default=None, help="Project root (default: cwd).")
    ap.add_argument("--catalog", default=None,
                    help="Catalog dir (default: ${CLAUDE_PLUGIN_ROOT}/catalog or <repo>/catalog).")
    ap.add_argument("--harness-root", default=None)
    ap.add_argument("--harness-yaml", default=None)
    ap.add_argument("--state", default=None)
    ap.add_argument("--deploy-root", default=None)
    ap.add_argument("--adopt-base", action="store_true",
                    help="Merge newly-released base components (available_base) into harness.yaml "
                         "as source:plugin and materialize them this run.")
    ap.add_argument("--eject", metavar="NAME", default=None,
                    help="Transfer a source:plugin component to source:custom ownership: vendor "
                         "the catalog bytes into harness/, rewrite its harness.yaml source line, "
                         "and flip the ledger entry. Dry-run by default; --apply executes.")
    args = ap.parse_args()

    apply = args.apply  # neither flag → plan
    project_root = Path(args.project_root or os.getcwd()).resolve()
    catalog = Path(args.catalog or (PLUGIN_ROOT / "catalog")).resolve()
    harness_root = Path(args.harness_root or (project_root / "harness"))
    harness_yaml = Path(args.harness_yaml or (harness_root / "harness.yaml"))
    deploy_root = Path(args.deploy_root or (project_root / ".claude")).resolve()
    state_path = Path(args.state or (deploy_root / ".harness-state.json"))
    anchor = deploy_root.parent

    if not catalog.is_dir():
        die(f"catalog not found: {catalog} (set CLAUDE_PLUGIN_ROOT or --catalog)", 2)

    # Eject is a standalone ownership transfer — it never reconciles. Exits when done.
    if args.eject:
        run_eject(args.eject, apply, catalog, harness_root, harness_yaml, state_path, anchor)

    # 1. Seed harness.yaml from the base set if absent; otherwise use it as-is.
    seeded = False
    if harness_yaml.exists():
        try:
            manifest = yaml.safe_load(harness_yaml.read_text()) or {}
        except yaml.YAMLError as e:
            die(f"harness.yaml parse error: {e}", 1)
    else:
        manifest = seed_manifest(catalog)
        seeded = True
        if apply:
            harness_yaml.parent.mkdir(parents=True, exist_ok=True)
            harness_yaml.write_text(render_manifest_yaml(manifest))

    validate_manifest(manifest)

    # Base-offering drift: base-tagged catalog components missing from the manifest. Informational
    # by default; --adopt-base merges them (source:plugin) into the manifest — and into harness.yaml
    # on apply — so they materialize this run (the gated "adopt new base" path).
    list_key_for = {kind: key for key, kind in _hs.LIST_KIND.items()}
    drift = base_drift(manifest, catalog)
    adopted = []
    if args.adopt_base and drift:
        additions = {}
        for d in drift:
            manifest.setdefault(list_key_for[d["kind"]], []).append(
                {"name": d["name"], "source": "plugin"})
            additions.setdefault(list_key_for[d["kind"]], []).append(d["name"])
        adopted, drift = drift, []
        if apply and harness_yaml.exists():
            harness_yaml.write_text(append_plugin_entries(harness_yaml.read_text(), additions))

    # 2. Plugin components + engine plan.
    desired, errors = build_plugin_desired(manifest, catalog, anchor)
    state = _hs.load_state(state_path)
    installed_all = state.get("components") or {}
    installed_plugin = {n: e for n, e in installed_all.items() if e.get("source") == "plugin"}

    plugin_version = read_plugin_version(catalog)

    # Version pins are HOLDs: while a manifest entry's `version:` differs from the catalog's
    # current version, the component is withdrawn from reconciliation — deployed bytes stay
    # put, the ledger is untouched, and the pending change surfaces in every plan until the
    # pin moves. (No background sync past a pin; re-pull stays explicit and reviewed.)
    held = []
    for name in sorted(desired):
        pin = desired[name].get("pin")
        if not pin or pin == plugin_version:
            continue
        d = desired.pop(name)
        ins = installed_plugin.pop(name, None)
        if ins is None:
            pending = "add"
        elif d["tree_hash"] != ins.get("source_hash") or d["profiles"] != ins.get("profiles"):
            pending = "update"
        else:
            pending = "none"
        held.append({"action": "hold", "name": name, "kind": d["kind"],
                     "pinned": pin, "available": plugin_version,
                     "deployed_version": (ins or {}).get("plugin_version"),
                     "pending": pending})

    actions, conflicts = _hs.reconcile(desired, installed_plugin, anchor, deploy_root, {})

    # Plans speak plugin versions: a cross-version update reports the transition
    # ("0.8.0 -> 0.9.0") instead of the bare hash pair; same-version byte drift (catalog
    # edited, no release) keeps the hash pair — there the hashes are the only signal.
    for a in actions:
        if a["action"] == "add" and plugin_version:
            a["new_version"] = plugin_version
        elif a["action"] == "update":
            old_v = (installed_plugin.get(a["name"]) or {}).get("plugin_version")
            a["old_version"], a["new_version"] = old_v, plugin_version
            if old_v and plugin_version and old_v != plugin_version:
                a["transition"] = f"{old_v} -> {plugin_version}"
                a.pop("old_hash", None)
                a.pop("new_hash", None)

    eng_out = engine_outputs(catalog, deploy_root)
    eng_hash = engine_hash(eng_out)
    eng_installed = state.get("engine") or {}
    if not eng_installed:
        eng_action = "add"
    elif eng_installed.get("source_hash") != eng_hash:
        eng_action = "update"
    else:
        eng_action = "noop"

    summary = _hs.summarize(actions, conflicts, errors)
    summary["hold"] = len(held)
    actions = actions + held
    result = {
        "mode": "apply" if apply else "plan",
        "catalog": str(catalog),
        "plugin_version": plugin_version,
        "deploy_root": _hs.relto(deploy_root, anchor),
        "seeded_harness_yaml": seeded,
        "available_base": drift,
        "adopted_base": adopted,
        "engine": {"action": eng_action, "files": len(eng_out)},
        "actions": actions,
        "conflicts": conflicts,
        "errors": errors,
        "summary": summary,
    }

    if not apply:
        print(json.dumps(result, indent=2))
        sys.exit(1 if (conflicts or errors) else 0)

    # 3. Apply: engine first (the runtime that everything else depends on), then components.
    materialize_engine(eng_out, eng_installed, anchor, deploy_root)
    new_engine = {
        "installed_paths": sorted(_hs.relto(dst, anchor) for _, dst in eng_out),
        "source_hash": eng_hash,
    }

    new_components = dict(installed_all)
    for a in actions:
        name, act = a["name"], a["action"]
        if act == "hold":
            a["applied"] = False   # pinned: deployed bytes stay put until the pin moves
            continue
        if act in ("add", "update"):
            entry = _hs.execute_install(desired[name], installed_plugin.get(name),
                                        anchor, deploy_root)
            if plugin_version:
                entry["plugin_version"] = plugin_version   # provenance stamp: add/update only
            new_components[name] = entry
        elif act == "remove":
            _hs.execute_remove(installed_plugin[name], anchor, deploy_root)
            new_components.pop(name, None)
        a["applied"] = True

    new_state = dict(state)
    new_state["version"] = _hs.STATE_VERSION
    new_state["components"] = new_components
    new_state["engine"] = new_engine
    _hs.write_state_atomic(state_path, new_state)

    result["state_path"] = _hs.relto(state_path, anchor)
    result["state_written"] = True
    result["engine"]["applied"] = True
    print(json.dumps(result, indent=2))
    sys.exit(1 if (conflicts or errors) else 0)


if __name__ == "__main__":
    main()

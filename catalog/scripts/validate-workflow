#!/usr/bin/env python3
"""
validate-workflow — structural + schema + DAG validation for a WORKFLOW.yaml.

Mirrors validate-microskill. Validates the deep-merge of WORKFLOW.yaml + any
profile overlays against workflow-schema.json, then runs DAG checks (node
shape, unique ids, depends_on completeness, ${ref} declaration, cycles, gate
and loop anchoring), resolves every use: target through the SAME
resolve-microskill subprocess the compiler uses (typed-ref checks fall back to
the resolved output_schema; inline-schema redundancy is linted), materializes
`wire: auto` pass-through forwards via the SAME shared helper as compile (an
unresolvable wire: auto target is always a block; auto-wiring a REQUIRED
target input warns), and lints redundant depends_on entries + undeclared
${workflow.inputs.x} refs.

TWO-MODE unresolvable-use: handling (intentional — stricter than the original
WARN+--strict spec):
  - WITH --defs-root (full-registry validation): an unresolvable / failed
    use: target is an UNCONDITIONAL BLOCK — fail-loud parity with
    compile-workflow's hard die. The caller explicitly named the registry, so
    a missing target is a real error, never an environment artifact.
  - STANDALONE (no --defs-root; the skill root is derived from the file's
    layout): it is a WARN, so hermetic single-file validation keeps passing
    when no microskill registry is reachable; --strict escalates it to a
    block. (--strict is the STANDALONE escalation knob only — with
    --defs-root the block is already unconditional.)

Usage:
  validate-workflow <WORKFLOW.yaml> [<profile.yaml> ...] [--defs-root <dir>] [--strict]

Stdout: {"pass": bool, "issues": [{"severity","location","message"}]}
Exit codes: 0 pass (no block) · 1 at least one block · 2 script/env error.
"""

import argparse
import copy
import importlib.machinery
import importlib.util
import json
import os
import re
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print(json.dumps({"error": "PyYAML not installed. pip3 install pyyaml"}))
    sys.exit(2)

try:
    from jsonschema import Draft202012Validator
except ImportError:
    print(json.dumps({"error": "jsonschema not installed. pip3 install jsonschema"}))
    sys.exit(2)

SCRIPT = Path(__file__).resolve()


def _templates_root(script):
    """Locate templates/ (schemas + component templates): an explicit
    MICROSKILLS_TEMPLATES_ROOT override wins (used by hermetic tests to pin the
    in-repo source schema before a reconcile materializes .claude/), then prefer
    the materialized runtime copy under .claude/, then ${CLAUDE_PLUGIN_ROOT},
    then the in-repo dogfood source."""
    proj = script.parents[2]
    cands = []
    override = os.environ.get("MICROSKILLS_TEMPLATES_ROOT")
    if override:
        cands.append(Path(override))
    cands.append(proj / ".claude" / "templates")
    env = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if env:
        cands.append(Path(env) / "templates")
    cands.append(proj / "templates")
    return next((c for c in cands if c.is_dir()), cands[0])


SCHEMA_PATH = _templates_root(SCRIPT) / "references" / "workflow-schema.json"

# Reuse the resolver's merge/strip helpers — single source of truth.
# resolve-microskill has no .py extension, so load it via SourceFileLoader.
_loader = importlib.machinery.SourceFileLoader(
    "resolve_microskill", str(SCRIPT.parent / "resolve-microskill"))
_spec = importlib.util.spec_from_loader("resolve_microskill", _loader)
_rm = importlib.util.module_from_spec(_spec)
_loader.exec_module(_rm)
deep_merge = _rm.deep_merge
strip_nulls = _rm.strip_nulls
substitute_vars = _rm.substitute_vars

# Reuse compile-workflow's SHARED DAG helpers so the two tools can never disagree
# on the edge model, topological order, or loop-body contiguity. compile-workflow
# guards main() under __name__=="__main__", so importing it is side-effect-free.
_cw_loader = importlib.machinery.SourceFileLoader(
    "compile_workflow", str(SCRIPT.parent / "compile-workflow"))
_cw_spec = importlib.util.spec_from_loader("compile_workflow", _cw_loader)
_cw = importlib.util.module_from_spec(_cw_spec)
_cw_loader.exec_module(_cw)
union_edges = _cw.union_edges
topo_sort = _cw.topo_sort
loop_contiguity_error = _cw.loop_contiguity_error
loop_while_until_error = _cw.loop_while_until_error
desugar_loop_until = _cw.desugar_loop_until
loop_max_parallel_errors = _cw.loop_max_parallel_errors
apply_workflow_vars = _cw.apply_workflow_vars
expand_static_fanout = _cw.expand_static_fanout
desugar_subgraphs = _cw.desugar_subgraphs
desugar_nested_workflows = _cw.desugar_nested_workflows
# Bounded-convergence grammar + until->while desugar run INSIDE the shared
# desugar_subgraphs (which validate calls), so they are not imported separately;
# only the contiguity check is re-run here against validate's own topo order.
subgraph_convergence_contiguity_error = _cw.subgraph_convergence_contiguity_error
scoped_ref_ids = _cw.scoped_ref_ids
resolve_microskill_directives = _cw.resolve_microskill_directives
wire_auto_placement_error = _cw.wire_auto_placement_error
auto_wire_node_inputs = _cw.auto_wire_node_inputs
gate_effective_options = _cw.gate_effective_options
gate_policy_errors = _cw.gate_policy_errors
gate_headless_errors = _cw.gate_headless_errors
loop_on_exhaust_errors = _cw.loop_on_exhaust_errors
loop_reserved_id_errors = _cw.loop_reserved_id_errors
synth_loop_exhaust_gate = _cw.synth_loop_exhaust_gate
LOOP_EXHAUST_GATE_ID = _cw.LOOP_EXHAUST_GATE_ID
LOOP_RESULT_ID = _cw.LOOP_RESULT_ID
_loop_vars = _cw._loop_vars
spill_placement_errors = _cw.spill_placement_errors
spill_schema_errors = _cw.spill_schema_errors
spill_guard_ref_errors = _cw.spill_guard_ref_errors
load_child_doc = _cw.load_child_doc
workflow_node_targets = _cw.workflow_node_targets
nested_workflow_depth_cycle_errors = _cw.nested_workflow_depth_cycle_errors
NODE_OUTPUT_FIELD_RE = _cw.NODE_OUTPUT_FIELD_RE
NODE_ITEMS_RE = _cw.NODE_ITEMS_RE

REF_RE = re.compile(r"\$\{([^}]*)\}")
NODE_OUTPUT_RE = re.compile(r"\b([a-z][a-z0-9_-]*)\.output\b")
AS_RE = re.compile(r"^[a-z][a-z0-9_]*$")  # safe JS identifier for for_each `as`
# A ${workflow.inputs.<name>} ref names a top-level workflow input — pure set
# membership against the declared inputs map (a misspelled name used to pass
# both tools and die at runtime as undefined).
WF_INPUT_RE = re.compile(r"\bworkflow\.inputs\.([A-Za-z_][A-Za-z0-9_]*)")
# Gate-choice comparisons: <gate-id>.output.choice ==/!= '<literal>' (and the
# JS ===/!== spellings, and the reversed literal-first order). The extracted
# literal is membership-checked against the gate's EFFECTIVE options — a
# casing/typo literal silently dead-ends both branches at run time.
GATE_CHOICE_CMP_RE = re.compile(
    r"\b([a-z][a-z0-9_-]*)\.output\.choice\s*(?:===|!==|==|!=)\s*"
    r"(?:'([^']*)'|\"([^\"]*)\")")
GATE_CHOICE_CMP_REV_RE = re.compile(
    r"(?:'([^']*)'|\"([^\"]*)\")\s*(?:===|!==|==|!=)\s*"
    r"([a-z][a-z0-9_-]*)\.output\.choice\b")
# Any reference to a gate's recorded choice (comparison or not) — used to FORCE
# a declared default on a warn gate whose choice is branched on.
GATE_CHOICE_REF_RE = re.compile(r"\b([a-z][a-z0-9_-]*)\.output\.choice\b")


def add(issues, severity, location, message):
    issues.append({"severity": severity, "location": location, "message": message})


def collect_strings(obj):
    """Yield every string value anywhere in a nested structure."""
    if isinstance(obj, str):
        yield obj
    elif isinstance(obj, dict):
        for v in obj.values():
            yield from collect_strings(v)
    elif isinstance(obj, list):
        for v in obj:
            yield from collect_strings(v)


def refs_in(obj):
    """All ${...} inner expressions found in any string under obj."""
    out = []
    for s in collect_strings(obj):
        out.extend(REF_RE.findall(s))
    return out


def required_inputs_of(doc):
    """Names of inputs marked required:true in a (parent or child) doc."""
    return {name for name, spec in (doc.get("inputs") or {}).items()
            if isinstance(spec, dict) and spec.get("required")}


def main():
    ap = argparse.ArgumentParser(description="Validate a WORKFLOW.yaml (+ optional profile overlays).")
    ap.add_argument("workflow", help="Path to WORKFLOW.yaml")
    ap.add_argument("configs", nargs="*", help="Optional profile YAML overlays to merge before validation")
    ap.add_argument("--defs-root", default=None,
                    help="Workflow-defs root enabling nested-workflow (workflow:) resolution checks "
                         "(import allowlist, target resolution, import-cycle, depth=1, required-child-input). "
                         "Also makes an unresolvable use: target an UNCONDITIONAL block — fail-loud "
                         "parity with compile-workflow's hard die (you named the registry, so a missing "
                         "target is a real error). Absent → the nested checks are skipped and an "
                         "unresolvable use: is a WARN (backward-compatible single-file validation).")
    ap.add_argument("--strict", action="store_true",
                    help="STANDALONE-mode escalation only: raise an unresolvable use: target from "
                         "WARN to a block when validating without --defs-root. Default keeps "
                         "hermetic standalone validation passing when no microskill registry is "
                         "reachable. With --defs-root the block is already unconditional, so this "
                         "flag adds nothing there.")
    args = ap.parse_args()

    issues = []

    wf_path = Path(args.workflow)
    if not wf_path.exists():
        add(issues, "block", "file", f"WORKFLOW.yaml not found: {wf_path}")
        print(json.dumps({"pass": False, "issues": issues}, indent=2))
        sys.exit(1)

    try:
        merged = yaml.safe_load(wf_path.read_text()) or {}
    except yaml.YAMLError as e:
        add(issues, "block", "file", f"WORKFLOW.yaml YAML parse error: {e}")
        print(json.dumps({"pass": False, "issues": issues}, indent=2))
        sys.exit(1)

    for cfg_path in args.configs:
        p = Path(cfg_path)
        if not p.exists():
            add(issues, "block", "config", f"profile not found: {p}")
            continue
        try:
            overlay = yaml.safe_load(p.read_text()) or {}
        except yaml.YAMLError as e:
            add(issues, "block", "config", f"{p.name} YAML parse error: {e}")
            continue
        if p.name != "base.yaml" and "profile" in overlay:
            add(issues, "block", "config", f"{p.name}: 'profile' block is base.yaml-only")
        try:
            merged = deep_merge(merged, overlay)
        except ValueError as e:
            add(issues, "block", "config", f"{p.name}: list-verb error: {e}")
            print(json.dumps({"pass": False, "issues": issues}, indent=2))
            sys.exit(1)

    merged = strip_nulls(merged)

    # --- INTRA-DEF VARS: {{snippet:NAME}} includes, then {{key}} vars (Phase 5b) ---
    # Mirror compile-workflow EXACTLY (shared apply_workflow_vars): substitute
    # {{snippet:NAME}} tokens from <defs-root>/_snippets/NAME.md FIRST (so a snippet
    # may carry vars), then {{key}} tokens from the top-level vars: map, AFTER
    # deep-merge + strip_nulls (so a profile may override a var) and BEFORE schema
    # validation. The snippets root is --defs-root when given, else derived from the
    # standard <defs-root>/<name>/WORKFLOW.yaml layout. An unresolved {{key}} is left
    # intact and surfaced as a WARN (never a crash/block), consistent with
    # resolve-microskill; an unresolvable SNIPPET is a HARD block (mirrors compile's
    # die — a missing include must never ship a literal token).
    if isinstance(merged, dict):
        snip_root = Path(args.defs_root) if args.defs_root else wf_path.resolve().parent.parent
        merged, unresolved_vars, snippet_errors = apply_workflow_vars(
            merged, snippets_dir=snip_root / "_snippets")
        for se in snippet_errors:
            add(issues, "block", "snippets", se)
        if snippet_errors:
            print(json.dumps({"pass": False, "issues": issues}, indent=2))
            sys.exit(1)
        for uk in unresolved_vars:
            add(issues, "warn", "vars", f"unresolved variable '{{{{{uk}}}}}' left intact")

    # --- COMPILE-TIME INLINE: flatten STATIC nested workflows (shared desugar) ---
    # Mirror compile-workflow: runs FIRST (before expand) so the combined flat graph's
    # expand:/subgraph: sugar all process uniformly. Needs the component registry, so
    # it runs only with --defs-root (a single-file validate skips nested-workflow
    # handling, exactly like the depth/cycle check below). A static (non-for_each)
    # workflow: node is spliced; a for_each one is left for the runtime. did_inline
    # gates the subgraph splice's reserved-'__' guard (it minted '__' ids itself).
    nw_did_inline = False
    if isinstance(merged, dict) and args.defs_root:
        merged, nw_inline_errors, nw_did_inline, _nw_regions = desugar_nested_workflows(
            merged, Path(args.defs_root))
        for ie in nw_inline_errors:
            add(issues, "block", "nested-workflow", ie)
        if nw_inline_errors:
            print(json.dumps({"pass": False, "issues": issues}, indent=2))
            sys.exit(1)
        # Per-region governance parity with compile (the inlined-child loop regions are
        # NOT re-checked by the parent loop's own validation, so a guarded loop-bearing
        # inline could pass validate yet die at compile). Run the cheap, statically
        # determinable checks compile runs per region: exactly-one-of while/until,
        # max_iters >= 1, and the reserved pseudo-result / exhaust-gate id collision.
        _reg_ids = ({n["id"] for n in (merged.get("nodes") or [])
                     if isinstance(n, dict) and isinstance(n.get("id"), str)}
                    | {g["id"] for g in (merged.get("gates") or [])
                       if isinstance(g, dict) and isinstance(g.get("id"), str)})
        for _ro, _rl, _rg in (_nw_regions or []):
            _wu = loop_while_until_error(_rl)
            if _wu:
                add(issues, "block", "nested-workflow",
                    f"loop region '{_ro}': {_wu}")
            _mi = _rl.get("max_iters")
            if not isinstance(_mi, int) or _mi < 1:
                add(issues, "block", "nested-workflow",
                    f"loop region '{_ro}': max_iters must be an integer >= 1 "
                    f"(got {_mi!r})")
            _rv = _loop_vars(_ro)
            for _rid in (_rv["result"], _rv["exhaust_gate"]):
                if _rid in _reg_ids:
                    add(issues, "block", "nested-workflow",
                        f"loop region '{_ro}': a node/gate id collides with its "
                        f"reserved key/gate id '{_rid}'")
        if any(i["severity"] == "block" for i in issues):
            print(json.dumps({"pass": False, "issues": issues}, indent=2))
            sys.exit(1)

    # --- COMPILE-TIME EXPAND: static fan-out templates (shared desugar) ---
    # Mirror compile-workflow EXACTLY: desugar expand:/inputs_each: immediately after
    # the vars pre-pass and BEFORE schema validation (the closed node schema never
    # sees the sugar; generated nodes are ordinary nodes validated below). A desugar
    # error is a HARD block — the half-desugared doc is structurally unusable, so
    # report and stop (mirrors the list-verb error path).
    # SNAPSHOT the hand-authored node list first (deep copy: the desugar mutates
    # inputs_each fan-in nodes in place): the redundant-depends_on lint below runs
    # against what the AUTHOR wrote — inputs_each desugars to inputs + an explicit
    # depends_on per generated sibling BY CONSTRUCTION, so generated nodes must
    # never trip the lint.
    pre_expand_nodes = []
    if isinstance(merged, dict):
        pre_expand_nodes = copy.deepcopy(
            [n for n in (merged.get("nodes") or []) if isinstance(n, dict)])
        merged, expand_errors = expand_static_fanout(merged)
        for ee in expand_errors:
            add(issues, "block", "expand", ee)
        if expand_errors:
            print(json.dumps({"pass": False, "issues": issues}, indent=2))
            sys.exit(1)

    # --- COMPILE-TIME SUBGRAPH: splice reusable node-groups (shared desugar) ---
    # Mirror compile-workflow EXACTLY (ONE shared desugar_subgraphs → no parity
    # drift): consume the `subgraph: <name>` node kind immediately after expand and
    # BEFORE the wf_-prefix check + schema validation, splicing it into the host DAG
    # as ordinary namespaced nodes the checks below validate. The registry root is
    # --defs-root when given, else derived from the standard
    # <defs-root>/<name>/WORKFLOW.yaml layout (same as the snippets root). A desugar
    # error is a HARD block (the half-spliced doc is structurally unusable).
    converge = {}
    if isinstance(merged, dict):
        sg_root = (Path(args.defs_root) if args.defs_root
                   else wf_path.resolve().parent.parent)
        merged, subgraph_errors, converge = desugar_subgraphs(
            merged, sg_root / "_subgraphs", check_reserved=not nw_did_inline)
        for se in subgraph_errors:
            add(issues, "block", "subgraph", se)
        if subgraph_errors:
            print(json.dumps({"pass": False, "issues": issues}, indent=2))
            sys.exit(1)

    # An OMITTED version defaults to 1 BEFORE schema validation (mirrors
    # compile-workflow / resolve-microskill). The const:1 check stays intact, so an
    # EXPLICIT wrong version still blocks.
    if isinstance(merged, dict):
        merged.setdefault("version", 1)

    # --- Schema validation (on the merged document) ---
    if SCHEMA_PATH.exists():
        schema = json.loads(SCHEMA_PATH.read_text())
        v = Draft202012Validator(schema)
        for e in sorted(v.iter_errors(merged), key=lambda e: list(e.path)):
            loc = "/".join(str(x) for x in e.path) or "<root>"
            add(issues, "block", f"schema:{loc}", e.message)
    else:
        add(issues, "block", "environment", f"workflow-schema.json not found: {SCHEMA_PATH}")

    # If schema already failed hard, structural assumptions below may not hold;
    # still attempt DAG checks defensively.
    nodes = merged.get("nodes") or []
    node_ids = []
    node_by_id = {}
    for i, n in enumerate(nodes):
        if not isinstance(n, dict):
            add(issues, "block", f"nodes[{i}]", "node is not a mapping")
            continue
        nid = n.get("id")
        if not nid:
            add(issues, "block", f"nodes[{i}]", "node missing id")
            continue
        if nid in node_by_id:
            add(issues, "block", f"nodes/{nid}", f"duplicate node id '{nid}'")
        # Reserved wf_ prefix: ${workflow.inputs.<x>} rides as _args.wf_<x> in
        # compiled segments and the run-step context, so a node id matching
        # ^wf_ silently clobbers (or is clobbered by) a workflow input in the
        # threaded args. Mirrors compile's hard die (defense in depth with the
        # schema id pattern). Runs post-expansion, so a desugar-generated
        # `<id>_<item>` collision (template id `wf` + item `x`) is caught too.
        if isinstance(nid, str) and nid.startswith("wf_"):
            add(issues, "block", f"nodes/{nid}",
                f"node id '{nid}' uses the reserved 'wf_' prefix — it collides "
                f"with the workflow-input args namespace "
                f"(${{workflow.inputs.<x>}} rides as _args.wf_<x> in compiled "
                f"segments and the run-step context); rename the node")
        node_ids.append(nid)
        node_by_id[nid] = n

    id_set = set(node_ids)

    # Gate-choice branching: a gate id is a legal ${<gate-id>.output.choice} ref
    # target (the dispatcher records the human's pick as results[gate.id]). Collect
    # the gate ids up front so the per-node ref check below ACCEPTS a gate-id ref
    # (not 'unknown node') and the typed-producer field-check SKIPS it (a gate has
    # no output_schema → treat as 'any', never flag). gate-0 already guarantees gate
    # ids are unique among gates AND disjoint from node ids, so this set is unambiguous.
    # Note: a gate-id ref must NOT become a dependency edge — the SHARED union_edges
    # helper only keeps refs whose id is a NODE id (a gate isn't in the node set), so a
    # gate-id ref contributes no edge and cannot perturb topo_sort.
    gate_id_set = {g.get("id") for g in (merged.get("gates") or [])
                   if isinstance(g, dict) and g.get("id")}

    # loop.on_exhaust: escalate — the loop segment commits a 'loop' pseudo-result
    # ({converged, rounds, carry}) and the compiler-synthesized 'loop_exhaust'
    # gate records its pick under that id, so BOTH become legal ${...} ref
    # producers (accepted like gate ids: no edge, no typed field-check). Scoped
    # to escalate — without it a ${loop.output.*} ref stays the unknown-node
    # block it is today.
    _loop_oe = (merged.get("loop") or {}).get("on_exhaust") \
        if isinstance(merged.get("loop"), dict) else None
    _oe_escalate = isinstance(_loop_oe, dict) and _loop_oe.get("action") == "escalate"
    if _oe_escalate:
        gate_id_set |= {LOOP_RESULT_ID, LOOP_EXHAUST_GATE_ID}

    # --- I-DECL: every ${workflow.inputs.<x>} ref must name a DECLARED input ---
    # Pure set membership over the whole merged doc (node fields, gate prompts,
    # loop, output — anywhere a ref can ride). A misspelled input name used to
    # pass both tools and surface at run time as `undefined`; now it blocks.
    declared_inputs = set((merged.get("inputs") or {}).keys()) \
        if isinstance(merged.get("inputs"), dict) else set()
    _reported_inputs = set()
    for inner in refs_in(merged):
        for in_name in WF_INPUT_RE.findall(inner):
            if in_name not in declared_inputs and in_name not in _reported_inputs:
                _reported_inputs.add(in_name)
                add(issues, "block", "inputs",
                    f"${{workflow.inputs.{in_name}}} is referenced but '{in_name}' is "
                    f"not declared in the workflow inputs map; at run time it would "
                    f"be undefined")

    # --- LINT: redundant depends_on (a ref already implies the edge) ---
    # Runs on the HAND-AUTHORED (pre-expand) nodes via the SHARED scoped_ref_ids
    # helper, so the lint and the union edge model can never disagree — and the
    # inputs_each-generated fan-in (explicit depends_on by construction) is
    # exempt. Warn-only: the union dedupes, so a restated edge is harmless noise.
    pre_ids = {n.get("id") for n in pre_expand_nodes if n.get("id")}
    for n in pre_expand_nodes:
        nid = n.get("id")
        if not nid:
            continue
        # A `workflow:` node is EXEMPT: it compile-time inlines a child region whose
        # internal nodes include zero-dep ones (e.g. implement-rvs's catalog_index,
        # depends_on: []). An output ref (${child.output...}) only orders the child's
        # producing node, leaving those zero-dep nodes free to float across the
        # region boundary — so depends_on on a workflow: node ANCHORS the whole
        # spliced region and is load-bearing for contiguity, never redundant noise.
        if n.get("workflow"):
            continue
        implied = {r for r in scoped_ref_ids(n) if r in pre_ids and r != nid}
        for d in (n.get("depends_on") or []):
            if d in implied:
                add(issues, "warn", f"nodes/{nid}/depends_on",
                    f"entry '{d}' is redundant — a ${{{d}.output...}}/${{{d}.items}} "
                    f"ref already implies the edge; drop it (depends_on is for pure "
                    f"ordering edges that carry no ref)")

    # --- VALIDATOR-SIDE SCHEMA INHERITANCE: resolve use: targets like compile ---
    # Each background use: node resolves through the SAME resolve-microskill
    # subprocess (and the same sibling-`microskills/` skill-root derivation)
    # compile-workflow uses, so the two tools read identical resolved
    # output_schemas. The resolved schema (a) feeds the typed-ref S-FIELD check
    # below as the fallback for a node with no inline schema, and (b) drives the
    # two-tier inline-schema redundancy lint (deep-equal → 'omit it'; divergent →
    # 'reconcile or document the narrowing').
    # Failure handling: with --defs-root (full-registry validation) an
    # unresolvable/failed use: is a BLOCK — fail-loud parity with compile's hard
    # die. Standalone (defs root derived from the WORKFLOW.yaml layout) it is a
    # WARN so hermetic single-file validation keeps passing; --strict escalates
    # it to a block. Explicit delegation: orchestrator (incl. the side_effect
    # alias) skips resolution in compile, so it skips all of this here too.
    resolve_defs_root = (Path(args.defs_root) if args.defs_root
                         else wf_path.parent.parent).resolve()
    skill_root = resolve_defs_root.parent / "microskills"
    unres_sev = "block" if (args.defs_root or args.strict) else "warn"
    resolved_schemas = {}
    resolved_payloads = {}
    _res_cache = {}
    for nid, n in node_by_id.items():
        use_name = n.get("use")
        if (not use_name or n.get("delegation") == "orchestrator"
                or n.get("side_effect") is True):
            continue
        # A wire: auto node's auto-wire set is computed FROM the resolution —
        # an unresolvable target makes it uncomputable, so the failure is a
        # BLOCK even in standalone (no --defs-root) validation, never the
        # hermetic-friendly warn (BLOCK, not fail-safe — verifier guardrail).
        node_unres_sev = "block" if n.get("wire") == "auto" else unres_sev
        ms_path = skill_root / str(use_name) / "MICROSKILL.md"
        if not ms_path.exists():
            # Cheap stat short-circuit — no subprocess when the target is absent.
            add(issues, node_unres_sev, f"nodes/{nid}",
                f"use: '{use_name}' does not resolve to {ms_path} (compile fails "
                f"loud on an unresolvable use: target; mark the node "
                f"delegation: orchestrator if a checkpoint is intended)")
            continue
        cust = n.get("customize") if isinstance(n.get("customize"), dict) else None
        prof = (cust or {}).get("profile")
        if isinstance(prof, str) and prof != "base" and \
                not (skill_root / str(use_name) / "profiles" / f"{prof}.yaml").exists():
            add(issues, node_unres_sev, f"nodes/{nid}",
                f"use: '{use_name}' customize.profile '{prof}' has no "
                f"profiles/{prof}.yaml (resolution silently falls back to base, "
                f"masking the typo)")
        key = (str(use_name), (cust or {}).get("profile"),
               json.dumps((cust or {}).get("overrides") or {}, sort_keys=True))
        if key not in _res_cache:
            _res_cache[key] = resolve_microskill_directives(
                use_name, cust, resolve_defs_root)
        resolved = _res_cache[key]
        if resolved["directives"] is None:
            add(issues, node_unres_sev, f"nodes/{nid}",
                f"use: '{use_name}' failed to resolve "
                f"({resolved.get('error') or 'resolution failed'})")
            continue
        rsch = resolved.get("output_schema")
        resolved_schemas[nid] = rsch
        resolved_payloads[nid] = resolved.get("payload")
        inline = n.get("output_schema")
        if isinstance(inline, dict) and rsch is not None:
            if inline == rsch:
                add(issues, "warn", f"nodes/{nid}/output_schema",
                    f"inline output_schema is identical to use: '{use_name}' "
                    f"resolved output_schema — omit it (a use: node inherits the "
                    f"resolved schema)")
            else:
                add(issues, "warn", f"nodes/{nid}/output_schema",
                    f"inline output_schema diverges from use: '{use_name}' "
                    f"resolved output_schema — reconcile them, or keep the "
                    f"override and document the narrowing")

    def _use_resolves_orchestrator(nid):
        """True when a resolved use: node carries an orchestrator-forcing directive
        (AskUserQuestion or a hard gate) — mirrors compile's classify() cases 5a/5b
        without re-shelling the resolver. False for an unresolved node (compile stays
        authoritative there)."""
        pl = resolved_payloads.get(nid)
        if not isinstance(pl, dict):
            return False
        d = pl.get("directives") or {}
        if "AskUserQuestion" in (d.get("allowed_tools") or []):
            return True
        return any((g or {}).get("severity", "hard") == "hard"
                   for g in (d.get("gates") or []))

    # --- wire: auto — materialize declared pass-through forwards (shared helper) ---
    # Mirrors compile EXACTLY (same auto_wire_node_inputs / wire_auto_placement_error
    # helpers, so the two tools can never disagree on the wired set): for an
    # opted-in node, every TARGET-declared, unsupplied input whose name matches a
    # declared workflow input gains inputs.<name>: ${workflow.inputs.<name>} —
    # explicit wins; wired pairs append sorted after the authored entries.
    # Materialized HERE: after the use: resolution pass above (the wire set needs
    # the target's declared inputs) and BEFORE the per-node ref checks and the
    # nested-workflow required-child-input check, so a wired input counts as
    # supplied exactly like a hand-written forward. Guardrails: a placement
    # violation is a BLOCK; an unresolvable use: target was escalated to a BLOCK
    # in the pass above (the wired set is uncomputable); an unreadable workflow:
    # child is a BLOCK here; auto-satisfying a REQUIRED target input is a WARN
    # (collision risk on generic names like 'name', where the right value is
    # often an upstream output, not the same-named workflow input).
    wf_inputs_map = merged.get("inputs") if isinstance(merged.get("inputs"), dict) else {}
    for nid, n in node_by_id.items():
        if n.get("wire") != "auto":
            continue
        perr = wire_auto_placement_error(n)
        if perr:
            add(issues, "block", f"nodes/{nid}", perr)
            continue
        if n.get("workflow"):
            doc, err = load_child_doc(resolve_defs_root, n["workflow"])
            if doc is None:
                add(issues, "block", f"nodes/{nid}",
                    f"wire: auto needs the child workflow's declared inputs, but "
                    f"workflow: '{n['workflow']}' {err}")
                continue
            target_inputs = doc.get("inputs") if isinstance(doc.get("inputs"), dict) else {}
        else:
            payload = resolved_payloads.get(nid)
            if payload is None:
                continue  # unresolvable use: — already a BLOCK above
            cfg = payload.get("config") if isinstance(payload.get("config"), dict) else {}
            target_inputs = cfg.get("inputs") if isinstance(cfg.get("inputs"), dict) else {}
        wired, required_wired = auto_wire_node_inputs(n, target_inputs, wf_inputs_map)
        for rname in required_wired:
            add(issues, "warn", f"nodes/{nid}",
                f"wire: auto satisfied REQUIRED target input '{rname}' from "
                f"${{workflow.inputs.{rname}}} — verify the same-named workflow "
                f"input is really the intended source")

    # --- use: node required-input satisfaction (block) ---
    # A use: node must supply every input its RESOLVED microskill marks required.
    # Source of truth = resolver's own required_inputs ledger (resolved_payloads[nid]
    # ["required_inputs"]): it already honors the customize.profile overlay AND
    # excludes inject_from inputs (env-supplied) — recomputing from the base config
    # over-blocks (the synthesize-review `design` profile flips fields optional).
    # wire:auto already mutated n['inputs'] in place above, so wired forwards count.
    for nid, n in node_by_id.items():
        if not n.get("use") or n.get("delegation") == "orchestrator" \
                or n.get("side_effect") is True:
            continue
        payload = resolved_payloads.get(nid)
        if not isinstance(payload, dict):
            continue  # unresolved (standalone/no-registry) — already warned/blocked above
        required = payload.get("required_inputs") or []
        supplied = set((n.get("inputs") or {}).keys())
        for req in sorted(set(required) - supplied):
            add(issues, "block", f"nodes/{nid}",
                f"use: '{n['use']}' requires input '{req}' (required) but the node's "
                f"inputs omit it (supply inputs.{req}: ${{...}}, or wire it)")

    # phase_group is a cosmetic /workflows progress-group label (emit-only). A
    # phase_group equal to a DIFFERENT node's id would merge that group's box with
    # that node's own box — deterministic but surprising; warn, never block. A node
    # whose phase_group equals its OWN id is a no-op (its default group already IS
    # its id) — nothing merges, so exclude it (pg != nid) to avoid a false positive.
    for nid, n in node_by_id.items():
        pg = n.get("phase_group")
        if pg and pg != nid and pg in id_set:
            add(issues, "warn", f"nodes/{nid}",
                f"phase_group '{pg}' collides with node id '{pg}'; their /workflows progress boxes will merge")

    # --- Per-node shape + ref-completeness ---
    for nid, n in node_by_id.items():
        has_use = bool(n.get("use"))
        has_agent = bool(n.get("agent"))
        has_wf = bool(n.get("workflow"))
        # side_effect: true is a readable alias for delegation: orchestrator
        # (compile normalizes it before classify); treat it as orchestrator here so
        # a side_effect node with neither use nor agent is exempt from the shape block.
        is_orch = n.get("delegation") == "orchestrator" or n.get("side_effect") is True
        # The three node kinds (use:/agent:/workflow:) are mutually exclusive.
        kinds = [k for k, present in
                 (("use", has_use), ("agent", has_agent), ("workflow", has_wf)) if present]
        if len(kinds) > 1:
            add(issues, "block", f"nodes/{nid}",
                f"node has more than one of use/agent/workflow ({', '.join(kinds)}); choose one")
        # A workflow: node is its own kind (an orchestrator checkpoint) — it is
        # exempt from the neither-use-nor-agent block.
        if not has_use and not has_agent and not has_wf and not is_orch:
            add(issues, "block", f"nodes/{nid}",
                "node has neither 'use' nor 'agent'; only allowed for an orchestrator-native step (delegation: orchestrator)")

        # FAIL-LOUD delegation contradictions (mirror compile's hard die):
        # delegation: auto cannot force a workflow: node into a background segment
        # (segments cannot re-enter the dispatcher), and side_effect: true (alias
        # for delegation: orchestrator) contradicts delegation: auto outright.
        if n.get("delegation") == "auto" and has_wf:
            add(issues, "block", f"nodes/{nid}",
                "delegation: auto on a workflow: node is invalid — a nested workflow "
                "always runs as an orchestrator checkpoint")
        if n.get("delegation") == "auto" and n.get("side_effect") is True:
            add(issues, "block", f"nodes/{nid}",
                "side_effect: true contradicts delegation: auto — a side-effect node "
                "must run as an orchestrator checkpoint; remove one of the two fields")

        # customize.overrides override the microskill's RESOLUTION — meaningful
        # ONLY on a use: node that actually resolves. Anywhere else they would
        # be silently ignored (mirror compile's hard die): a workflow:/agent:/
        # orchestrator-native node has no resolution, and explicit
        # delegation: orchestrator (incl. its side_effect alias) SKIPS it.
        cust = n.get("customize")
        cust_overrides = (cust or {}).get("overrides") if isinstance(cust, dict) else None
        if cust_overrides:
            if not has_use:
                add(issues, "block", f"nodes/{nid}",
                    "customize.overrides is only valid on a use: microskill node; "
                    "on a workflow:/agent:/orchestrator node it would be silently "
                    "ignored")
            elif is_orch:
                add(issues, "block", f"nodes/{nid}",
                    "customize.overrides cannot take effect under explicit "
                    "delegation: orchestrator (resolution is skipped, so the "
                    "overrides would be silently ignored); remove one of the two")

        # retry lives in compiled segment JS — valid on a background use:/agent:
        # node only. Block the statically-detectable orchestrator placements
        # (compile also dies when resolution-driven classification, e.g. an
        # AskUserQuestion microskill, makes a retry node a checkpoint).
        if n.get("retry"):
            if has_wf or (not has_use and not has_agent):
                add(issues, "block", f"nodes/{nid}",
                    "retry is only valid on a background use:/agent: node; a "
                    "workflow:/orchestrator node never runs inside a compiled "
                    "segment, so its retry would be silently dropped")
            elif is_orch:
                add(issues, "block", f"nodes/{nid}",
                    "retry is only honored in a background segment, but this node "
                    "is an explicit orchestrator checkpoint "
                    "(delegation: orchestrator / side_effect: true)")

        depends = n.get("depends_on") or []
        for d in depends:
            if d not in id_set:
                add(issues, "block", f"nodes/{nid}/depends_on", f"references unknown node '{d}'")

        # S-INFER: a ${<id>.output...} ref IMPLIES a dependency edge (no longer
        # requires an explicit depends_on entry). We still guard genuine typos:
        # the referenced id must be a real node. S-FIELD: when the referenced
        # producer carries an object output_schema with declared properties, the
        # FIRST field after .output must be one of them. A producer with NO
        # inline schema falls back to its RESOLVED microskill output_schema
        # (validator-side inheritance — same precedence as compile: explicit
        # wins, resolution fills absence). A producer with neither (agent node,
        # unresolvable use:, schema-less microskill) is 'any' and never flagged.
        scoped = {k: n.get(k) for k in ("inputs", "prompt", "when", "for_each") if k in n}
        for s in collect_strings(scoped):
            for inner in REF_RE.findall(s):
                for ref_id in NODE_OUTPUT_RE.findall(inner):
                    # A gate-id ref (e.g. ${g.output.choice}) is legal — a gate is a
                    # checkpoint, not a node; accept it and require no depends_on edge.
                    if ref_id not in id_set and ref_id not in gate_id_set:
                        add(issues, "block", f"nodes/{nid}",
                            f"references output of unknown node '{ref_id}'")
                for prod_id, field in NODE_OUTPUT_FIELD_RE.findall(inner):
                    if _oe_escalate and prod_id == LOOP_RESULT_ID:
                        # the loop pseudo-result is TYPED ({converged, rounds,
                        # carry}) — a typo'd field would silently read
                        # undefined and dead-end the branch
                        if field not in ("converged", "rounds", "carry"):
                            add(issues, "block", f"nodes/{nid}",
                                f"references ${{loop.output.{field}}} but the "
                                f"loop pseudo-result declares only "
                                f"converged/rounds/carry")
                        continue
                    if prod_id in gate_id_set:
                        continue  # gate has no output_schema → 'any', never field-check
                    if prod_id not in id_set:
                        continue  # already reported by the unknown-node guard above
                    osch = node_by_id[prod_id].get("output_schema")
                    if osch is None:
                        osch = resolved_schemas.get(prod_id)
                    if not (isinstance(osch, dict)
                            and osch.get("type") == "object"
                            and isinstance(osch.get("properties"), dict)):
                        continue  # schema-less / non-object producer → 'any', never flagged
                    if field not in osch["properties"]:
                        add(issues, "block", f"nodes/{nid}",
                            f"references ${{{prod_id}.output.{field}}} but node "
                            f"'{prod_id}' output_schema does not declare property '{field}'")
                # FEATURE A: ${<id>.items} consumes the WHOLE per-item-results array of a
                # fan-out node <id>. Like ${<id>.output} it implies the edge <id>->nid
                # (handled by the SHARED scoped_ref_ids/union_edges). Here the typo +
                # misuse guards: unknown <id> blocks; an <id> that is a node but NOT a
                # for_each node blocks (no per-item array to consume — clear misuse).
                # NODE_OUTPUT_FIELD_RE never matches `.items`, so the typed-producer
                # field-check above cannot interfere.
                for ref_id in NODE_ITEMS_RE.findall(inner):
                    if ref_id not in id_set:
                        add(issues, "block", f"nodes/{nid}",
                            f"references per-item results of unknown node '{ref_id}' "
                            f"(${{{ref_id}.items}})")
                    elif not node_by_id[ref_id].get("for_each"):
                        add(issues, "block", f"nodes/{nid}",
                            f"references ${{{ref_id}.items}} but node '{ref_id}' is not a "
                            f"for_each node; there is no per-item results array to consume")

        # for_each fan-out requires an `as` binding that is a safe identifier.
        has_for_each = bool(n.get("for_each"))
        as_var = n.get("as")
        if has_for_each and not as_var:
            add(issues, "block", f"nodes/{nid}/for_each",
                "for_each requires an 'as' loop-variable name")
        if as_var and not AS_RE.match(str(as_var)):
            add(issues, "block", f"nodes/{nid}",
                f"'as' must match ^[a-z][a-z0-9_]*$ (safe identifier), got '{as_var}'")
        if as_var and not has_for_each:
            add(issues, "warn", f"nodes/{nid}", "'as' declared without 'for_each'; it has no effect")

    # --- for_each source array-type lint (warn) ---
    # A for_each whose source is a CLEAN whole-value ref ${prod.output.field} should
    # iterate an array; warn if the producer's schema declares that field non-array.
    # Method-chained sources (${...items.filter(...)}) are not statically typeable —
    # skip them (they would false-warn). ${x.items} is always an array — skip.
    _CLEAN_FE_RE = re.compile(r"^\$\{\s*([a-z][a-z0-9_-]*)\.output\.([A-Za-z_][A-Za-z0-9_]*)\s*\}$")
    for nid, n in node_by_id.items():
        fe = n.get("for_each")
        if not isinstance(fe, str):
            continue
        m = _CLEAN_FE_RE.match(fe.strip())
        if not m:
            continue  # ${x.items}, method chains, multi-token exprs — un-typeable here
        prod_id, field = m.group(1), m.group(2)
        if prod_id not in node_by_id:
            continue  # unknown producer already blocked by the ref checks above
        osch = node_by_id[prod_id].get("output_schema") or resolved_schemas.get(prod_id)
        if not (isinstance(osch, dict) and isinstance(osch.get("properties"), dict)):
            continue
        fld = osch["properties"].get(field)
        if isinstance(fld, dict) and fld.get("type") and fld.get("type") != "array":
            add(issues, "warn", f"nodes/{nid}/for_each",
                f"for_each iterates ${{{prod_id}.output.{field}}} but node "
                f"'{prod_id}' declares '{field}' as type '{fld.get('type')}', not array "
                f"— fan-out needs an array source")

    # --- bare-identifier ref existence (block) ---
    # A ${ident} with no dot (e.g. ${finding}) is a runtime lookup that resolves only
    # to the CONTAINING node's own for_each `as` var. Everything else is dotted —
    # workflow inputs ride ${workflow.inputs.x}, node outputs ride ${id.output...},
    # and a loop carry var rides ${loop.carry.<v>} (DAG-RULES §loop; a BARE ${v} is
    # NOT a carry binding) — so all of those are skipped by the dot guard below. We
    # scope the scan to node ref-bearing fields (inputs/prompt/when/for_each),
    # matching the S-INFER node-ref scan, and only flag a lowercase identifier (the
    # `as`-var naming) so a capitalized template token is left alone.
    _BARE_RE = re.compile(r"^[a-z][a-z0-9_]*$")
    for nid, n in node_by_id.items():
        own_as = n.get("as") if n.get("for_each") else None
        legal_bare = {own_as} if own_as else set()
        scoped = {k: n.get(k) for k in ("inputs", "prompt", "when", "for_each") if k in n}
        reported = set()
        for s in collect_strings(scoped):
            for inner in REF_RE.findall(s):
                tok = inner.strip()
                if "." in tok or not _BARE_RE.match(tok):
                    continue  # dotted refs + non-identifier tokens handled elsewhere
                if tok in legal_bare or tok in reported:
                    continue
                reported.add(tok)
                add(issues, "block", f"nodes/{nid}",
                    f"bare reference ${{{tok}}} resolves to no for_each binding "
                    f"(this node's `as`); node outputs ride ${{<id>.output...}}, "
                    f"workflow inputs ride ${{workflow.inputs.<name>}}, and a loop "
                    f"carry var rides ${{loop.carry.{tok}}} — all require a dotted path")

    # --- spill_outputs: declared node-output-by-reference (shared checks) ---
    # Mirrors compile EXACTLY (same shared helpers — the two tools can never
    # disagree): (a) placement — spill_outputs on a for_each fan-out node is a
    # block (the result is an ARRAY; no single <node>.<field> value to spill);
    # (b) schema coherence — every spilled field must exist in the producer's
    # EFFECTIVE output schema (inline wins, else the resolved microskill schema
    # — validator-side inheritance; a schema-less producer is 'any', never
    # flagged); (c) HARD-BLOCK — a spilled field referenced in a when /
    # for_each guard or the loop while/until: across a checkpoint the
    # dispatcher threads that field as a handoff file PATH, and a path is not
    # the value (always truthy, never equal to the value's literals, not an
    # array), so the guard would silently mis-branch every run.
    spill_nodes = [n for n in nodes if isinstance(n, dict) and n.get("id")]
    for sp_nid, sp_msg in spill_placement_errors(spill_nodes):
        add(issues, "block", f"nodes/{sp_nid}/spill_outputs", sp_msg)
    for nid, n in node_by_id.items():
        spill = n.get("spill_outputs")
        if not spill:
            continue
        eff_schema = n.get("output_schema")
        if eff_schema is None:
            eff_schema = resolved_schemas.get(nid)
        for ss_msg in spill_schema_errors(nid, spill, eff_schema):
            add(issues, "block", f"nodes/{nid}/spill_outputs", ss_msg)
    sg_loop = merged.get("loop") if isinstance(merged.get("loop"), dict) else None
    for sg_loc, sg_msg in spill_guard_ref_errors(spill_nodes, sg_loop):
        add(issues, "block", sg_loc, sg_msg)

    # --- Branch-exclusivity lint (rank12, STRENGTHENED): bounded comparison analysis ---
    # Catches the malformed-fork footgun: sibling nodes (identical effective
    # dependency set) that form an advisory fork which is NOT mutually exclusive.
    # Within the locked design (branch = exclusivity-lint only — no forks:
    # construct), the lint now runs a BOUNDED comparison-pattern analysis on each
    # when-guard pair:
    #   - PROVABLY BOTH FIRE (textually identical guards, or guards whose bounded
    #     parse yields the same canonical comparison, e.g. `x != 1` vs `!(x == 1)`)
    #     → BLOCK: a deterministic guard pair that always fires together can never
    #     be an exclusive fork.
    #   - same-field guards that are neither identical nor provably disjoint
    #     (e.g. `x > 0` vs `x > 1` — overlapping ranges) → WARN: both branches may
    #     fire together for some values.
    #   - provably disjoint (`x == null` vs `x != null`, `x > 0` vs `x == 0`,
    #     truthy vs falsy, distinct == literals, non-overlapping numeric ranges)
    #     → clean.
    # The grammar is deliberately bounded — one field, one comparison operator, one
    # null/bool/number/string literal, any !-parity and balanced parens; anything
    # else parses to None and falls back to the textual-identity check only. This
    # composes with gate-choice branching (forks guarded on ${gate.output.choice}
    # literals parse as string comparisons and prove disjoint when literals differ).
    def _norm_when(w):
        return re.sub(r"\s+", "", str(w)) if w else None

    def _strip_outer_parens(s):
        while s.startswith("(") and s.endswith(")"):
            depth = 0
            whole = True
            for i, ch in enumerate(s):
                if ch == "(":
                    depth += 1
                elif ch == ")":
                    depth -= 1
                    if depth == 0 and i < len(s) - 1:
                        whole = False  # closes before the end → not one wrapper
                        break
            if not whole or depth != 0:
                break
            s = s[1:-1].strip()
        return s

    _GUARD_CMP_RE = re.compile(
        r"^(?P<field>[A-Za-z_][\w.]*)\s*"
        r"(?:(?P<op>===|!==|==|!=|>=|<=|>|<)\s*"
        r"(?P<lit>null|true|false|-?\d+(?:\.\d+)?|'[^']*'|\"[^\"]*\"))?$")
    _NEG_OP = {"==": "!=", "!=": "==", ">": "<=", "<=": ">", "<": ">=", ">=": "<",
               "truthy": "falsy", "falsy": "truthy"}

    def _parse_guard(when):
        """Bounded parse of a when-guard → canonical (field, op, value) or None.
        op ∈ {==,!=,>,>=,<,<=,truthy,falsy}; value is a (kind, payload) literal
        tuple (None for truthy/falsy). Negation folds into the operator."""
        if not isinstance(when, str):
            return None
        s = when.strip()
        m = re.fullmatch(r"\$\{(.*)\}", s, flags=re.S)
        if m:
            s = m.group(1).strip()
        if "${" in s:
            return None  # embedded refs beyond one whole-value wrapper → unknown
        neg = False
        while True:
            stripped = _strip_outer_parens(s)
            if stripped != s:
                s = stripped
                continue
            if s.startswith("!"):
                rest = s[1:].strip()
                # JS precedence: unary ! binds tighter than any comparison, so
                # a bare `!<field> <op> <literal>` means `(!<field>) <op>
                # <literal>` — folding the negation across the operator would
                # invert the wrong thing. Folding is sound only for
                # `!(<comparison>)`, `!<field>` (truthiness) and chained unary
                # `!`; anything else falls out of the bounded grammar (None).
                if not (rest.startswith("(") or rest.startswith("!")
                        or re.fullmatch(r"[A-Za-z_][\w.]*", rest)):
                    return None
                neg = not neg
                s = rest
                continue
            break
        m = _GUARD_CMP_RE.match(s)
        if not m:
            return None
        field, op, lit = m.group("field"), m.group("op"), m.group("lit")
        if op is None:
            return (field, "falsy" if neg else "truthy", None)
        op = {"===": "==", "!==": "!="}.get(op, op)
        if neg:
            op = _NEG_OP[op]
        if lit == "null":
            value = ("null", None)
        elif lit in ("true", "false"):
            value = ("bool", lit == "true")
        elif lit[0] in "'\"":
            value = ("str", lit[1:-1])
        else:
            value = ("num", float(lit))
        return (field, op, value)

    def _interval(op, x):
        """Numeric comparison as (lo, hi, lo_closed, hi_closed), or None for !=."""
        inf = float("inf")
        return {"==": (x, x, True, True), ">": (x, inf, False, True),
                ">=": (x, inf, True, True), "<": (-inf, x, True, False),
                "<=": (-inf, x, True, True)}.get(op)

    def _provably_disjoint(p1, p2):
        """True only when the two same-field comparisons can NEVER both hold."""
        (_, op1, v1), (_, op2, v2) = p1, p2
        ops = {op1, op2}
        if ops == {"truthy", "falsy"}:
            return True
        if "truthy" in ops or "falsy" in ops:
            return False
        if op1 == "==" and op2 == "==":
            return v1 != v2
        if ops == {"==", "!="}:
            return v1 == v2
        if v1 is not None and v2 is not None and v1[0] == "num" and v2[0] == "num":
            i1, i2 = _interval(op1, v1[1]), _interval(op2, v2[1])
            if i1 and i2:
                (alo, ahi, aloc, ahic), (blo, bhi, bloc, bhic) = i1, i2
                if ahi < blo or bhi < alo:
                    return True
                if ahi == blo and not (ahic and bloc):
                    return True
                if bhi == alo and not (bhic and aloc):
                    return True
        return False

    # Effective sibling key = the UNION edge set (explicit depends_on + ref-implied),
    # so siblings are compared on what actually gates them, not just literal
    # depends_on. A node with no `when` (unconditional) is never a fork branch.
    fork_edges = union_edges([n for n in nodes if isinstance(n, dict) and n.get("id")])
    fork_groups = {}
    for nid in node_ids:
        if not node_by_id[nid].get("when"):
            continue
        fork_groups.setdefault(frozenset(fork_edges.get(nid, set())), []).append(nid)
    for dep_set, members in fork_groups.items():
        if len(members) < 2:
            continue
        dep_desc = ("{" + ", ".join(sorted(dep_set)) + "}") if dep_set else "{}"
        members = sorted(members)
        for i in range(len(members)):
            for j in range(i + 1, len(members)):
                a, b = members[i], members[j]
                wa, wb = node_by_id[a].get("when"), node_by_id[b].get("when")
                pa, pb = _parse_guard(wa), _parse_guard(wb)
                if _norm_when(wa) == _norm_when(wb) or (pa is not None and pa == pb):
                    add(issues, "block", "nodes",
                        f"sibling nodes [{a}, {b}] share dependencies {dep_desc} and "
                        f"their 'when' guards provably BOTH fire (equivalent "
                        f"conditions); this fork is not mutually exclusive — negate "
                        f"or change one")
                elif pa is not None and pb is not None and pa[0] == pb[0] \
                        and not _provably_disjoint(pa, pb):
                    add(issues, "warn", "nodes",
                        f"sibling nodes [{a}, {b}] share dependencies {dep_desc} and "
                        f"guard the same field '{pa[0]}' with conditions that are "
                        f"neither identical nor provably disjoint; both branches may "
                        f"fire together — verify the fork is exclusive")

    # --- Cycle detection over the UNION edge set (refs + depends_on) ---
    # CRITICAL: a ref-only cycle (A reads ${B.output}, B reads ${A.output}, neither
    # in depends_on) must be caught — so we DFS the same union edges compile orders
    # over, not depends_on alone.
    well_formed_nodes = [n for n in nodes if isinstance(n, dict) and n.get("id")]
    edges = union_edges(well_formed_nodes)
    WHITE, GRAY, BLACK = 0, 1, 2
    color = {nid: WHITE for nid in id_set}
    cycle_found = [False]

    def visit(u, stack):
        color[u] = GRAY
        for d in sorted(edges.get(u, set())):
            if d not in color:
                continue
            if color[d] == GRAY:
                add(issues, "block", "nodes", f"dependency cycle: {' -> '.join(stack + [u, d])}")
                cycle_found[0] = True
                return
            if color[d] == WHITE:
                visit(d, stack + [u])
        color[u] = BLACK

    for nid in sorted(id_set):
        if color[nid] == WHITE:
            visit(nid, [])

    # --- Gates anchoring + id uniqueness/disjointness ---
    # Gate ids share the ${<id>.output} namespace with node ids, so they must be
    # unique among gates AND disjoint from node ids — otherwise a future feature
    # keying off a gate id (e.g. recording a human choice in results[gate.id])
    # produces an ambiguous reference.
    seen_gate_ids = set()
    gates_after = {}
    for g in merged.get("gates") or []:
        if not isinstance(g, dict):
            continue
        gid = g.get("id")
        if gid:
            if gid in seen_gate_ids:
                add(issues, "block", f"gates/{gid}", f"duplicate gate id '{gid}'")
            if gid in id_set:
                add(issues, "block", f"gates/{gid}",
                    f"gate id '{gid}' collides with a node id; ids must be disjoint across nodes and gates")
            seen_gate_ids.add(gid)
        after = g.get("after")
        if after and after not in id_set:
            add(issues, "block", f"gates/{g.get('id','?')}", f"'after' references unknown node '{after}'")
        if after:
            gates_after.setdefault(after, []).append(g)

    # --- SUBGRAPH bounded convergence: each group occupies a contiguous topo window
    # (no interleaved out-of-group node, no hard/human_approval gate between its
    # spliced nodes). Mirror compile via the SAME shared helper (parity by
    # construction); only safe to topo-sort when the union graph is acyclic (a cycle
    # is already reported above). Grammar + until->while were enforced inside the
    # shared desugar_subgraphs, so a bounded subgraph reaches here already validated.
    if converge and not cycle_found[0]:
        sg_contig = subgraph_convergence_contiguity_error(
            topo_sort(well_formed_nodes), node_by_id, gates_after, converge)
        if sg_contig:
            add(issues, "block", "subgraph", sg_contig)
    # PARITY with compile's per-segment split die (compile-workflow:~3277): an
    # in-group use: node that RESOLVES to an orchestrator (AskUserQuestion / a hard
    # gate) forces a checkpoint flush mid-group, splitting the bounded group across
    # segments so the local do/while can't wrap it. The static
    # _subgraph_static_orchestrator guard (inside the shared desugar) catches only
    # STATIC signals; this resolution-driven case is caught here exactly as the
    # loop-body path at :1367 — needs no topo (independent of cycle_found).
    if converge:
        for sid in sorted(converge):
            for nid in converge[sid]["node_ids"]:
                bn = node_by_id.get(nid)
                if isinstance(bn, dict) and bn.get("use") and _use_resolves_orchestrator(nid):
                    add(issues, "block", "subgraph",
                        f"subgraph '{sid}': inner node '{nid}' resolves to an "
                        f"orchestrator checkpoint (its microskill exposes "
                        f"AskUserQuestion or carries a hard gate) — a bounded "
                        f"convergence group must be entirely background, or it splits "
                        f"across segments and the local do/while can't wrap it")

    # --- Declared gate policy: defaults + headless coherence (shared helpers) ---
    # Same gate_policy_errors / gate_headless_errors compile-workflow dies on, so
    # the two tools can never disagree: a declared `default` must be one of the
    # gate's EFFECTIVE options (declared options, or the implicit confirm/stop
    # pair of an options-less gate); on_headless: take_default needs a default;
    # and a merged doc that DECLARES gate_mode: auto (e.g. an autonomous profile
    # overlay) must leave no pausing gate without a default or an explicit
    # on_headless: fail.
    gates_list = [g for g in (merged.get("gates") or []) if isinstance(g, dict)]
    gate_by_id = {g.get("id"): g for g in gates_list if g.get("id")}
    for p_gid, p_msg in gate_policy_errors(gates_list):
        add(issues, "block", f"gates/{p_gid}", p_msg)
    if merged.get("gate_mode") == "auto":
        for h_gid, h_msg in gate_headless_errors(gates_list):
            add(issues, "block", f"gates/{h_gid}", h_msg)

    # loop.on_exhaust: escalate — the synthetic gate is born at COMPILE time
    # (post-merge), so it is absent from gates_list; run the SAME rails on an
    # equivalently-synthesized dict here, or a bad escalate config would pass
    # validate and die at compile: default ∈ effective options, take_default
    # needs a default, and (doc-declared gate_mode: auto only — validate has no
    # --gate-mode flag) the pausing exhaustion gate needs a default or
    # on_headless: fail. Registering it in gate_by_id also gives
    # ${loop_exhaust.output.choice} comparison literals the standard
    # options-membership check. Reserved ids ride the shared helper.
    _loop_last_body = None
    if _oe_escalate:
        _synth_gate = synth_loop_exhaust_gate(_loop_oe)
        # Anchor the synthetic gate exactly where compile anchors it — after
        # the loop body's LAST topo-order node, PREPENDED to that anchor's
        # gate list (decl pos -1: it fires before any authored same-anchor
        # gate) — so the present-path fires-before machinery below enforces
        # the same ordering for paths naming `loop_exhaust` as for authored
        # gates, instead of silently skipping the check.
        _oe_body = [b for b in ((merged.get("loop") or {}).get("body") or [])
                    if b in id_set]
        if not cycle_found[0] and _oe_body:
            _oe_pos = {n: i for i, n in enumerate(topo_sort(well_formed_nodes))}
            _loop_last_body = max(_oe_body, key=lambda b: _oe_pos.get(b, -1))
            _synth_gate["after"] = _loop_last_body
        for _p_gid, p_msg in gate_policy_errors([_synth_gate]):
            add(issues, "block", "loop/on_exhaust", p_msg)
        if merged.get("gate_mode") == "auto":
            for _h_gid, h_msg in gate_headless_errors([_synth_gate]):
                add(issues, "block", "loop/on_exhaust",
                    f"{h_msg} (the compiler-emitted '{LOOP_EXHAUST_GATE_ID}' "
                    f"gate rides the same headless rails as authored gates)")
        gate_by_id.setdefault(LOOP_EXHAUST_GATE_ID, _synth_gate)
    for r_loc, r_msg in loop_reserved_id_errors(
            merged.get("nodes") or [], merged.get("gates") or [],
            merged.get("loop")):
        add(issues, "block", r_loc, r_msg)

    # --- INERT/DROPPED declarations (warn-only — no runtime effect) ---
    # grant_tools is schema-declared on a node but never consumed by the engine.
    for nid, n in node_by_id.items():
        if n.get("grant_tools"):
            add(issues, "warn", f"nodes/{nid}",
                "grant_tools is schema-declared but the engine never consumes it "
                "(no-op); remove it or grant the tool via the microskill's runtime")
    # A workflow input declared materialize:file is passed BY REFERENCE as a short
    # file PATH; by convention its name ends _path so downstream reads read-a-path.
    for in_name, spec in (wf_inputs_map or {}).items():
        if isinstance(spec, dict) and spec.get("materialize") == "file" \
                and not str(in_name).endswith("_path"):
            add(issues, "warn", "inputs",
                f"input '{in_name}' is materialize:file (threaded by reference as a "
                f"file path) but its name does not end in '_path'; rename for clarity")

    # --- present: declared gate presentation — checked, then rendered MECHANICALLY ---
    # A gate's `present` is an ordered list of field paths the dispatcher renders
    # verbatim (the model output-rubric is only the fallback), so the approver
    # sees the SAME evidence every run. Checks: (a) the leading id must be a known
    # node (or an EARLIER gate — only `choice` is ever recorded for a gate);
    # (b) a typed producer's first field after .output must be declared (same
    # machinery as the node-ref S-FIELD check, resolved-schema inheritance
    # included); (c) the producer must already have RUN when the gate fires — the
    # gate fires immediately after its `after` node, so a path may only name a
    # node at-or-before that anchor in the shared topo order (a later node's
    # result would render undefined on every run).
    order_pos = ({o_nid: i for i, o_nid in enumerate(topo_sort(well_formed_nodes))}
                 if not cycle_found[0] else None)
    gate_decl_pos = {g.get("id"): i for i, g in enumerate(gates_list) if g.get("id")}
    if _oe_escalate:
        # compile PREPENDS the synthetic gate at its anchor — same-anchor
        # authored gates fire after it
        gate_decl_pos.setdefault(LOOP_EXHAUST_GATE_ID, -1)

    def present_paths(g):
        for entry in (g.get("present") or []):
            if isinstance(entry, str):
                yield entry
            elif isinstance(entry, dict) and isinstance(entry.get("read_file"), str):
                yield entry["read_file"]

    for g in gates_list:
        gid = g.get("id", "?")
        after = g.get("after")
        loc = f"gates/{gid}/present"
        for path in present_paths(g):
            parts = path.split(".")
            lead, field = parts[0], (parts[2] if len(parts) > 2 else None)
            if _oe_escalate and lead == LOOP_RESULT_ID:
                # the loop pseudo-result is a TYPED producer with a fixed
                # contract, produced by the loop segment (anchor = its last
                # topo-order body node) — not a gate, despite riding
                # gate_id_set for the unknown-producer acceptance
                if (order_pos is not None and after in order_pos
                        and _loop_last_body in order_pos
                        and order_pos[_loop_last_body] > order_pos[after]):
                    add(issues, "block", loc,
                        f"path '{path}' references the loop pseudo-result, but "
                        f"the loop segment completes after this gate's anchor "
                        f"'{after}' — not yet produced when the gate fires")
                    continue
                if field is not None and field not in ("converged", "rounds", "carry"):
                    add(issues, "block", loc,
                        f"path '{path}': the loop pseudo-result records only "
                        f"{{converged, rounds, carry}} — field '{field}' is "
                        f"never recorded")
                continue
            if lead in gate_id_set:
                if lead == gid:
                    add(issues, "block", loc,
                        f"path '{path}' references this gate's own choice — not yet "
                        f"recorded when the gate fires")
                    continue
                src = gate_by_id.get(lead) or {}
                if (order_pos is not None and after in order_pos
                        and src.get("after") in order_pos):
                    fires_before = (
                        order_pos[src["after"]] < order_pos[after]
                        or (src["after"] == after
                            and gate_decl_pos.get(lead, 0) < gate_decl_pos.get(gid, 0)))
                    if not fires_before:
                        add(issues, "block", loc,
                            f"path '{path}' references gate '{lead}', which fires at or "
                            f"after this gate — its choice is not yet recorded")
                        continue
                if field is not None and field != "choice":
                    add(issues, "block", loc,
                        f"path '{path}': a gate records only {{choice}} — field "
                        f"'{field}' is never recorded")
                continue
            if lead not in id_set:
                add(issues, "block", loc,
                    f"path '{path}' references unknown node '{lead}'")
                continue
            if (order_pos is not None and after in order_pos and lead in order_pos
                    and order_pos[lead] > order_pos[after]):
                add(issues, "block", loc,
                    f"path '{path}' references node '{lead}', which runs after this "
                    f"gate's anchor '{after}' — not yet produced when the gate fires")
                continue
            if field is not None:
                p_osch = node_by_id[lead].get("output_schema")
                if p_osch is None:
                    p_osch = resolved_schemas.get(lead)
                if (isinstance(p_osch, dict) and p_osch.get("type") == "object"
                        and isinstance(p_osch.get("properties"), dict)
                        and field not in p_osch["properties"]):
                    add(issues, "block", loc,
                        f"path '{path}' names field '{field}' but node '{lead}' "
                        f"output_schema does not declare property '{field}'")

    # --- Gate-choice literal cross-check ---
    # Every string literal compared against ${<gate-id>.output.choice} must be a
    # member of that gate's EFFECTIVE options: the dispatcher only ever records
    # one of the offered labels (or the declared default, verbatim), so a literal
    # outside the set makes the comparison CONSTANT — a casing typo silently
    # dead-ends both branches of a fork. Bounded extraction in the same spirit as
    # the exclusivity lint's comparison grammar: ==/!= (and the JS ===/!==
    # spellings), one quoted literal, either operand order; anything more complex
    # is out of grammar and skipped.
    choice_scan = [(f"nodes/{s_nid}",
                    {k: s_n.get(k) for k in ("inputs", "prompt", "when", "for_each")
                     if k in s_n})
                   for s_nid, s_n in node_by_id.items()]
    if isinstance(merged.get("loop"), dict):
        choice_scan.append(
            ("loop", {k: merged["loop"].get(k) for k in ("while", "carry")}))

    def choice_literal_hits(obj):
        for s in collect_strings(obj):
            for m in GATE_CHOICE_CMP_RE.finditer(s):
                yield m.group(1), (m.group(2) if m.group(2) is not None else m.group(3))
            for m in GATE_CHOICE_CMP_REV_RE.finditer(s):
                yield m.group(3), (m.group(1) if m.group(1) is not None else m.group(2))

    for c_loc, scoped_obj in choice_scan:
        for ref_gid, lit in choice_literal_hits(scoped_obj):
            cg = gate_by_id.get(ref_gid)
            if cg is None:
                continue  # not a gate id — a node's own output is 'any', out of scope
            c_opts = gate_effective_options(cg)
            if lit not in c_opts:
                c_suffix = ("" if cg.get("options")
                            else " (an options-less gate offers the implicit "
                                 "confirm/stop pair)")
                add(issues, "block", c_loc,
                    f"compares ${{{ref_gid}.output.choice}} against '{lit}', which is "
                    f"not one of gate '{ref_gid}' options {c_opts}{c_suffix} — the "
                    f"recorded choice is always one of the gate's offered labels, so "
                    f"this comparison is constant and the branch is dead")

    # --- dead-guard enum-literal lint (block) ---
    # A when/for_each guard comparing a node-output field that declares an `enum`
    # against a literal OUTSIDE that enum is constant (== always false, != always
    # true) — the branch is dead. Generalizes the gate-choice literal cross-check to
    # typed node outputs. Bounded via _parse_guard (one field, one comparison, one
    # literal); anything outside the grammar parses to None and is skipped.
    _GUARD_FIELD_RE = re.compile(r"^([a-z][a-z0-9_-]*)\.output\.([A-Za-z_][A-Za-z0-9_]*)$")
    for nid, n in node_by_id.items():
        for key in ("when", "for_each"):
            parsed = _parse_guard(n.get(key))
            if parsed is None:
                continue
            field_expr, op, value = parsed
            if op not in ("==", "!=") or value is None or value[0] not in ("str", "num", "bool"):
                continue
            fm = _GUARD_FIELD_RE.match(field_expr)
            if not fm:
                continue
            prod_id, fld = fm.group(1), fm.group(2)
            if prod_id not in node_by_id:
                continue
            osch = node_by_id[prod_id].get("output_schema") or resolved_schemas.get(prod_id)
            if not (isinstance(osch, dict) and isinstance(osch.get("properties"), dict)):
                continue
            spec = osch["properties"].get(fld)
            enum = spec.get("enum") if isinstance(spec, dict) else None
            if not isinstance(enum, list) or not enum:
                continue
            # compare the literal against enum members (members are scalars)
            lit = value[1]
            if lit not in enum:
                add(issues, "block", f"nodes/{nid}",
                    f"guard '{key}' compares ${{{prod_id}.output.{fld}}} against "
                    f"{lit!r}, not a member of its declared enum {enum} — the "
                    f"comparison is constant and the branch is dead")

    # --- FORCE a default on a warn gate whose choice is branched on ---
    # The dispatcher no longer fabricates a pick at a non-pausing gate: a warn
    # human_approval gate records its DECLARED default verbatim, or {choice: null}
    # when none is declared — so branching on a defaultless warn gate's choice
    # could never fire. And a warn gate of any non-human_approval type emits NO
    # checkpoint at all (dropped at compile), so its choice is NEVER recorded.
    referenced_gids = set()
    for _c_loc, scoped_obj in choice_scan:
        for s in collect_strings(scoped_obj):
            referenced_gids.update(GATE_CHOICE_REF_RE.findall(s))
    for g in gates_list:
        gid = g.get("id")
        if not gid or gid not in referenced_gids:
            continue
        if g.get("severity", "hard") != "warn":
            continue  # a hard gate pauses — the human's pick is always recorded
        if g.get("type") != "human_approval":
            add(issues, "block", f"gates/{gid}",
                f"${{{gid}.output.choice}} is branched on, but a warn gate of type "
                f"'{g.get('type')}' emits no checkpoint at all (dropped at compile) — "
                f"its choice is never recorded; make it human_approval or severity: hard")
        elif g.get("default") is None:
            add(issues, "block", f"gates/{gid}",
                f"${{{gid}.output.choice}} is branched on, but this warn gate declares "
                f"no 'default' — a warn gate never pauses, and the dispatcher records "
                f"the DECLARED default verbatim (or {{choice: null}} when none; never a "
                f"fabricated pick), so the branch could never fire; declare default:")

    # A severity:warn gate of a non-human_approval type emits NO checkpoint at all
    # (dropped at compile), so its present/prompt are dead. The branched-on case is
    # already a BLOCK above; here we warn the NOT-branched-on case so the dead
    # declaration is still surfaced.
    for g in gates_list:
        gid = g.get("id")
        if not gid or gid in referenced_gids:
            continue  # branched-on warn gates already handled by the block above
        if g.get("severity", "hard") == "warn" and g.get("type") != "human_approval":
            add(issues, "warn", f"gates/{gid}",
                f"gate '{gid}' is severity:warn and type '{g.get('type')}' — it emits "
                f"no checkpoint at all (dropped at compile), so its present/prompt are "
                f"dead; make it human_approval, or severity:hard, or drop it")

    # --- max_parallel placement: only valid on a for_each node (shared with compile) ---
    for mp_id, mp_msg in loop_max_parallel_errors(well_formed_nodes):
        add(issues, "block", f"nodes/{mp_id}/max_parallel", mp_msg)

    # max_parallel on a for_each node that classifies orchestrator is silently
    # dropped (an orchestrator checkpoint fans out serially in the main loop), so
    # the cap is inert. Structural orchestrators (delegation/side_effect/workflow:/
    # neither-use-nor-agent) and resolution-driven ones (AskUserQuestion / hard gate).
    for nid, n in node_by_id.items():
        if not n.get("max_parallel") or not n.get("for_each"):
            continue
        structural_orch = (n.get("delegation") == "orchestrator"
                           or n.get("side_effect") is True
                           or n.get("workflow")
                           or not (n.get("use") or n.get("agent") or n.get("workflow")))
        if structural_orch or (n.get("use") and _use_resolves_orchestrator(nid)):
            add(issues, "warn", f"nodes/{nid}/max_parallel",
                "max_parallel is set on a for_each node that classifies as an "
                "orchestrator checkpoint; it fans out serially in the main loop, so "
                "max_parallel is inert here and silently dropped")

    # --- Loop anchoring ---
    loop = merged.get("loop")
    if isinstance(loop, dict):
        # LOOP ERGONOMICS: exactly one of while/until, then desugar until→while so the
        # ref/contiguity checks below run against the same condition compile emits.
        wu_err = loop_while_until_error(loop)
        if wu_err:
            add(issues, "block", "loop", wu_err)
        desugar_loop_until(loop)
        # A GUARDED body (any `when`-guarded member) stays serial — its __ran
        # bookkeeping can't ride a concurrent batch — so compile keeps the serial
        # emit and a for_each fan-out there is still rejected. An UNGUARDED body
        # routes through the rank emitter, where a for_each node composes as its own
        # `await parallel(map(...))` rank inside the do/while, so it is now legal.
        body_guarded = any(node_by_id.get(b, {}).get("when")
                           for b in (loop.get("body") or []))
        for b in loop.get("body") or []:
            if b not in id_set:
                add(issues, "block", "loop/body", f"references unknown node '{b}'")
                continue
            bn = node_by_id.get(b, {})
            if bn.get("for_each") and body_guarded:
                add(issues, "block", "loop/body",
                    f"node '{b}' uses for_each in a GUARDED loop body (a `when`-guarded "
                    f"member forces the serial emit); fan-out is supported only in an "
                    f"unguarded loop body")
            # FAIL-LOUD (statically-detectable subset; mirrors compile's hard die):
            # an orchestrator-classified body member splits the body across steps
            # and silently drops the do/while scaffold. Block the cases visible
            # without microskill resolution: explicit delegation: orchestrator /
            # side_effect: true, a workflow: node, and an orchestrator-native step
            # (neither use nor agent). A use: node that auto-classifies orchestrator
            # via resolution (AskUserQuestion / hard gate) is caught by compile.
            if (bn.get("delegation") == "orchestrator" or bn.get("side_effect") is True
                    or bn.get("workflow")
                    or not (bn.get("use") or bn.get("agent") or bn.get("workflow"))):
                add(issues, "block", "loop/body",
                    f"node '{b}' is an orchestrator checkpoint (explicit "
                    f"delegation/side_effect, a workflow: node, or no use/agent); a "
                    f"loop body must be entirely background — an orchestrator member "
                    f"breaks the do/while scaffold")
            elif bn.get("use") and _use_resolves_orchestrator(b):
                add(issues, "block", "loop/body",
                    f"node '{b}' resolves to an orchestrator checkpoint (its "
                    f"microskill exposes AskUserQuestion or carries a hard gate); a "
                    f"loop body must be entirely background")
        if "max_iters" not in loop:
            add(issues, "block", "loop", "missing required 'max_iters' cap")
        # on_exhaust coherence (shared helper; the synthetic gate's policy/
        # headless rails already ran in the gates section above): gate-shaped
        # fields only under escalate, default: extend refused, notes_input must
        # name a declared workflow input.
        for oe_msg in loop_on_exhaust_errors(
                loop, merged.get("inputs")
                if isinstance(merged.get("inputs"), dict) else {}):
            add(issues, "block", "loop/on_exhaust", oe_msg)
        for inner in refs_in({"while": loop.get("while"), "carry": loop.get("carry")}):
            for ref_id in NODE_OUTPUT_RE.findall(inner):
                if ref_id not in id_set and ref_id not in gate_id_set:
                    add(issues, "block", "loop", f"references output of unknown node '{ref_id}'")
            for prod_id, field in NODE_OUTPUT_FIELD_RE.findall(inner):
                if _oe_escalate and prod_id == LOOP_RESULT_ID:
                    if field not in ("converged", "rounds", "carry"):
                        add(issues, "block", "loop",
                            f"references ${{loop.output.{field}}} but the loop "
                            f"pseudo-result declares only converged/rounds/carry")
                    continue
                if prod_id in gate_id_set or prod_id not in id_set:
                    continue
                # INVERSE of the ${id.items}-on-a-NON-for_each block (~705-708): a
                # for_each producer's runtime result is the per-item ARRAY, not an
                # object. A scalar ${fe.output.<field>} ref in while/until/carry
                # compiles to `n_fe = await parallel(map(...))` (an array) and then
                # `(!n_fe.<field>)` → undefined → the loop can never converge (spins to
                # max_iters / throws under on_exhaust:fail). A fan-out result is
                # consumable only as the whole array via ${fe.items}.
                if node_by_id[prod_id].get("for_each"):
                    add(issues, "block", "loop",
                        f"references ${{{prod_id}.output.{field}}} but node '{prod_id}' "
                        f"is a for_each fan-out; its result is the per-item results "
                        f"array, not an object — consume the whole array via "
                        f"${{{prod_id}.items}}, never a scalar .output field")
                    continue
                osch = node_by_id[prod_id].get("output_schema")
                if osch is None:
                    osch = resolved_schemas.get(prod_id)
                if not (isinstance(osch, dict) and osch.get("type") == "object"
                        and isinstance(osch.get("properties"), dict)):
                    continue
                if field not in osch["properties"]:
                    add(issues, "block", "loop",
                        f"references ${{{prod_id}.output.{field}}} but node "
                        f"'{prod_id}' output_schema does not declare property '{field}'")

        # CONVERGENCE: a loop.while that references nothing iteration-local — no
        # body-node output and no carry var — re-evaluates to the same value every
        # round, so the loop can never converge early (only the max_iters cap stops
        # it). Warn (a constant-true while + max_iters is a legitimate fixed-count
        # loop, just rarely intended).
        body_id_set = set(loop.get("body") or [])
        carry_keys = set((loop.get("carry") or {}).keys())
        while_refs = refs_in({"while": loop.get("while")})
        touches_local = any(
            rid in body_id_set
            for inner in while_refs for rid in NODE_OUTPUT_RE.findall(inner))
        # A carry var is referenced via the dotted ${loop.carry.<v>} form ONLY
        # (DAG-RULES §loop; compile uses the same \bloop\.carry\.(\w+) regex), so
        # match that exact shape — a coarse identifier scan would collide with node
        # ids / the literal 'output' and wrongly suppress the warn.
        touches_carry = any(
            ck in carry_keys
            for inner in while_refs
            for ck in re.findall(r"\bloop\.carry\.([A-Za-z0-9_]+)", inner))
        if loop.get("while") and while_refs and not touches_local and not touches_carry:
            add(issues, "warn", "loop",
                "loop.while references nothing iteration-local (no loop-body node "
                "output and no carry var); it re-evaluates identically each round so "
                "the loop can only stop at max_iters — verify the continue-condition")

        # S-LOOP: loop.body must occupy a CONTIGUOUS window in topological order
        # with no interleaved orchestrator/out-of-body node and no hard/human_approval
        # gate anchored between body nodes. A split body silently drops the do/while
        # scaffold in compile yet would otherwise pass:true here. Mirror compile's
        # shared check (same topo order, same helper). Only safe to topo-sort when
        # the union graph is acyclic — a cycle is already reported above.
        body_ids = loop.get("body") or []
        if (not cycle_found[0]
                and all(b in id_set for b in body_ids)
                and not any(node_by_id.get(b, {}).get("for_each") for b in body_ids)):
            order = topo_sort(well_formed_nodes)
            contig_err = loop_contiguity_error(order, node_by_id, gates_after, loop)
            if contig_err:
                add(issues, "block", "loop/body", contig_err)

            # on_exhaust needs the body to form its OWN segment (compile dies
            # on the full partition; this blocks the PROVABLE static subset):
            # a provably-background node (agent:, no orchestrator markers)
            # topo-adjacent to the body with no hard gate / orchestrator
            # boundary between them merges into the loop segment — `fail`
            # silently evaporates and `escalate` emits an unsatisfiable gate.
            # use: nodes are skipped here (resolution may reclassify them);
            # compile remains authoritative.
            oe_doc = loop.get("on_exhaust")
            if (isinstance(oe_doc, dict)
                    and oe_doc.get("action") in ("fail", "escalate") and body_ids):
                pos = {n: i for i, n in enumerate(order)}
                lo = min(pos[b] for b in body_ids)
                hi = max(pos[b] for b in body_ids)

                def _provably_background(nb):
                    return (isinstance(nb, dict) and nb.get("agent")
                            and nb.get("delegation") != "orchestrator"
                            and nb.get("side_effect") is not True)

                def _hard_gate_after(anchor_id):
                    return any(gg.get("type") == "human_approval"
                               or gg.get("severity", "hard") == "hard"
                               for gg in gates_after.get(anchor_id, []))

                neighbors = []
                if lo > 0:
                    neighbors.append((order[lo - 1], order[lo - 1]))
                # under escalate the synthetic gate flushes after the last
                # body node, so only `fail` can merge a TRAILING neighbor
                if oe_doc.get("action") == "fail" and hi + 1 < len(order):
                    neighbors.append((order[hi + 1], order[hi]))
                for nbr, boundary_anchor in neighbors:
                    if (_provably_background(node_by_id.get(nbr, {}))
                            and not _hard_gate_after(boundary_anchor)):
                        add(issues, "block", "loop/on_exhaust",
                            f"background node '{nbr}' is topo-adjacent to the "
                            f"loop body with no checkpoint between them — it "
                            f"merges into the loop segment, so the on_exhaust "
                            f"policy cannot attach; separate it with a hard "
                            f"gate or an orchestrator checkpoint")

    # --- output anchoring ---
    out = merged.get("output")
    if isinstance(out, dict) and out.get("from") and out["from"] not in id_set:
        add(issues, "block", "output", f"'from' references unknown node '{out['from']}'")

    # (use: target existence/resolution now runs unconditionally in the
    # validator-side schema-inheritance pass above: block with --defs-root,
    # warn standalone, --strict escalates.)

    # --- Nested-workflow (workflow:) resolution — only with --defs-root ---
    # LOCKED: when --defs-root is ABSENT these checks are skipped, so existing
    # single-file invocations of validate-workflow stay backward-compatible.
    wf_nodes = [(nid, n) for nid, n in node_by_id.items() if n.get("workflow")]
    if args.defs_root and wf_nodes:
        defs_root = Path(args.defs_root)
        imports_set = {imp for imp in (merged.get("imports") or []) if isinstance(imp, str)}

        # Resolve + cache every reachable child doc once (PURE: WORKFLOW.yaml only).
        child_cache = {}

        def child_doc(name):
            if name not in child_cache:
                child_cache[name] = load_child_doc(defs_root, name)
            return child_cache[name]

        def child_required(target, doc, profile):
            """Required child inputs computed on the child's base.yaml + the parent
            node's customize.profile overlay (mirrors runtime profile resolution),
            not the raw child WORKFLOW.yaml. Falls back to the raw doc when no
            overlay files are present."""
            merged_child = doc
            base_p = defs_root / target / "profiles" / "base.yaml"
            if base_p.exists():
                try:
                    b = yaml.safe_load(base_p.read_text()) or {}
                    b.pop("version", None)
                    merged_child = deep_merge(merged_child, b)
                except (yaml.YAMLError, ValueError):
                    merged_child = doc
            if isinstance(profile, str) and profile not in (None, "", "base"):
                prof_p = defs_root / target / "profiles" / f"{profile}.yaml"
                if prof_p.exists():
                    try:
                        o = yaml.safe_load(prof_p.read_text()) or {}
                        o.pop("version", None)  # symmetric with base + compile's merge
                        merged_child = deep_merge(merged_child, o)
                    except (yaml.YAMLError, ValueError):
                        pass
            return required_inputs_of(merged_child)

        for nid, n in wf_nodes:
            target = n["workflow"]
            # (a) target must be declared in the imports allowlist.
            if target not in imports_set:
                add(issues, "block", f"nodes/{nid}",
                    f"workflow: '{target}' is not listed in the top-level 'imports' allowlist")
                continue
            # (b) target must resolve to a child WORKFLOW.yaml.
            doc, err = child_doc(target)
            if doc is None:
                add(issues, "block", f"nodes/{nid}",
                    f"workflow: '{target}' {err}")
                continue
            # (c) DEPTH=1 now runs via the SHARED
            # nested_workflow_depth_cycle_errors helper below (compile dies on
            # the same findings — the two tools can never disagree).
            # (d) N4 child contract (PURE, from child WORKFLOW.yaml): every
            # required child input must be supplied by this node's inputs.
            supplied = set((n.get("inputs") or {}).keys())
            _child_prof = (n.get("customize") or {}).get("profile")
            for req in sorted(child_required(target, doc, _child_prof)):
                if req not in supplied:
                    add(issues, "block", f"nodes/{nid}",
                        f"workflow: '{target}' requires input '{req}' but the node's inputs omit it")
            # (d2) customize.profile (when set) must resolve to a child profile
            # overlay file. 'base' is always implicit, so it needs no overlay.
            prof = (n.get("customize") or {}).get("profile")
            if isinstance(prof, str) and prof != "base":
                if not (defs_root / target / "profiles" / f"{prof}.yaml").exists():
                    add(issues, "block", f"nodes/{nid}",
                        f"workflow: '{target}' customize.profile '{prof}' "
                        f"has no profiles/{prof}.yaml")
            # (e) N4 output-shape reference: WARN (not block) when a
            # ${<nid>.output.<field>} ref names a field the child's declared output
            # node does not expose.
            child_out = doc.get("output")
            child_fields = None
            if isinstance(child_out, dict) and child_out.get("from"):
                cby = {cn.get("id"): cn for cn in (doc.get("nodes") or [])
                       if isinstance(cn, dict)}
                producer = cby.get(child_out["from"])
                if isinstance(producer, dict):
                    osch = producer.get("output_schema")
                    if osch is None and producer.get("use"):
                        # resolve the child producer's microskill schema (inheritance)
                        rc_ = resolve_microskill_directives(
                            producer["use"],
                            producer.get("customize") if isinstance(producer.get("customize"), dict) else None,
                            defs_root)
                        osch = rc_.get("output_schema")
                    if isinstance(osch, dict) and isinstance(osch.get("properties"), dict):
                        child_fields = set(osch["properties"].keys())
            if child_fields is not None:
                pat = re.compile(r"\b" + re.escape(nid) + r"\.output\.([a-zA-Z0-9_]+)")
                for other_id, other in node_by_id.items():
                    refsrc = {k: other.get(k) for k in
                              ("inputs", "prompt", "when", "for_each") if k in other}
                    for s in collect_strings(refsrc):
                        for fld in pat.findall(s):
                            if fld not in child_fields:
                                add(issues, "warn", f"nodes/{other_id}",
                                    f"references ${{{nid}.output.{fld}}} but child workflow "
                                    f"'{target}' output does not declare field '{fld}'")

        # (c)+(f) DEPTH=1 + import-cycle DFS: the SHARED helper compile-workflow
        # also hard-dies on (same adjacency — each doc's workflow: targets
        # restricted to its own imports allowlist; un-allowlisted/unresolvable
        # targets are reported by the blocks above, never walked).
        for nw_loc, nw_msg in nested_workflow_depth_cycle_errors(defs_root, merged):
            add(issues, "block", nw_loc, nw_msg)

    passed = not any(i["severity"] == "block" for i in issues)
    print(json.dumps({"pass": passed, "issues": issues}, indent=2))
    sys.exit(0 if passed else 1)


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""
validate-workflow — structural + schema + DAG validation for a WORKFLOW.yaml.

Mirrors validate-microskill. Validates the deep-merge of WORKFLOW.yaml + any
profile overlays against workflow-schema.json, then runs DAG checks (node
shape, unique ids, depends_on completeness, ${ref} declaration, cycles, gate
and loop anchoring).

Usage:
  validate-workflow <WORKFLOW.yaml> [<profile.yaml> ...]

Stdout: {"pass": bool, "issues": [{"severity","location","message"}]}
Exit codes: 0 pass (no block) · 1 at least one block · 2 script/env error.
"""

import argparse
import importlib.machinery
import importlib.util
import json
import os
import re
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print(json.dumps({"error": "PyYAML not installed. pip3 install pyyaml"}))
    sys.exit(2)

try:
    from jsonschema import Draft202012Validator
except ImportError:
    print(json.dumps({"error": "jsonschema not installed. pip3 install jsonschema"}))
    sys.exit(2)

SCRIPT = Path(__file__).resolve()


def _templates_root(script):
    """Locate templates/ (schemas + component templates): an explicit
    MICROSKILLS_TEMPLATES_ROOT override wins (used by hermetic tests to pin the
    in-repo source schema before a reconcile materializes .claude/), then prefer
    the materialized runtime copy under .claude/, then ${CLAUDE_PLUGIN_ROOT},
    then the in-repo dogfood source."""
    proj = script.parents[2]
    cands = []
    override = os.environ.get("MICROSKILLS_TEMPLATES_ROOT")
    if override:
        cands.append(Path(override))
    cands.append(proj / ".claude" / "templates")
    env = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if env:
        cands.append(Path(env) / "templates")
    cands.append(proj / "templates")
    return next((c for c in cands if c.is_dir()), cands[0])


SCHEMA_PATH = _templates_root(SCRIPT) / "references" / "workflow-schema.json"

# Reuse the resolver's merge/strip helpers — single source of truth.
# resolve-microskill has no .py extension, so load it via SourceFileLoader.
_loader = importlib.machinery.SourceFileLoader(
    "resolve_microskill", str(SCRIPT.parent / "resolve-microskill"))
_spec = importlib.util.spec_from_loader("resolve_microskill", _loader)
_rm = importlib.util.module_from_spec(_spec)
_loader.exec_module(_rm)
deep_merge = _rm.deep_merge
strip_nulls = _rm.strip_nulls

REF_RE = re.compile(r"\$\{([^}]*)\}")
NODE_OUTPUT_RE = re.compile(r"\b([a-z][a-z0-9_-]*)\.output\b")
AS_RE = re.compile(r"^[a-z][a-z0-9_]*$")  # safe JS identifier for for_each `as`


def add(issues, severity, location, message):
    issues.append({"severity": severity, "location": location, "message": message})


def collect_strings(obj):
    """Yield every string value anywhere in a nested structure."""
    if isinstance(obj, str):
        yield obj
    elif isinstance(obj, dict):
        for v in obj.values():
            yield from collect_strings(v)
    elif isinstance(obj, list):
        for v in obj:
            yield from collect_strings(v)


def refs_in(obj):
    """All ${...} inner expressions found in any string under obj."""
    out = []
    for s in collect_strings(obj):
        out.extend(REF_RE.findall(s))
    return out


def load_child_doc(defs_root, name):
    """PURE child read: load <defs-root>/<name>/WORKFLOW.yaml as a dict.
    Never touches the child's .compiled/manifest.json (compile/validate must stay
    byte-identical-deterministic w.r.t. a single source — the WORKFLOW.yaml).
    Returns (doc, error_message): doc is None when the file is missing/unparseable."""
    wf = Path(defs_root) / name / "WORKFLOW.yaml"
    if not wf.exists():
        return None, f"does not resolve to {wf}"
    try:
        return (yaml.safe_load(wf.read_text()) or {}), None
    except yaml.YAMLError as e:
        return None, f"child '{name}' WORKFLOW.yaml parse error: {e}"


def workflow_node_targets(doc):
    """The child-workflow names referenced by this doc's workflow: nodes (in order)."""
    out = []
    for n in (doc.get("nodes") or []):
        if isinstance(n, dict) and n.get("workflow"):
            out.append(n["workflow"])
    return out


def required_inputs_of(doc):
    """Names of inputs marked required:true in a (parent or child) doc."""
    return {name for name, spec in (doc.get("inputs") or {}).items()
            if isinstance(spec, dict) and spec.get("required")}


def main():
    ap = argparse.ArgumentParser(description="Validate a WORKFLOW.yaml (+ optional profile overlays).")
    ap.add_argument("workflow", help="Path to WORKFLOW.yaml")
    ap.add_argument("configs", nargs="*", help="Optional profile YAML overlays to merge before validation")
    ap.add_argument("--defs-root", default=None,
                    help="Workflow-defs root enabling nested-workflow (workflow:) resolution checks "
                         "(import allowlist, target resolution, import-cycle, depth=1, required-child-input). "
                         "Absent → those checks are skipped (backward-compatible single-file validation).")
    args = ap.parse_args()

    issues = []

    wf_path = Path(args.workflow)
    if not wf_path.exists():
        add(issues, "block", "file", f"WORKFLOW.yaml not found: {wf_path}")
        print(json.dumps({"pass": False, "issues": issues}, indent=2))
        sys.exit(1)

    try:
        merged = yaml.safe_load(wf_path.read_text()) or {}
    except yaml.YAMLError as e:
        add(issues, "block", "file", f"WORKFLOW.yaml YAML parse error: {e}")
        print(json.dumps({"pass": False, "issues": issues}, indent=2))
        sys.exit(1)

    for cfg_path in args.configs:
        p = Path(cfg_path)
        if not p.exists():
            add(issues, "block", "config", f"profile not found: {p}")
            continue
        try:
            overlay = yaml.safe_load(p.read_text()) or {}
        except yaml.YAMLError as e:
            add(issues, "block", "config", f"{p.name} YAML parse error: {e}")
            continue
        if p.name != "base.yaml" and "profile" in overlay:
            add(issues, "block", "config", f"{p.name}: 'profile' block is base.yaml-only")
        try:
            merged = deep_merge(merged, overlay)
        except ValueError as e:
            add(issues, "block", "config", f"{p.name}: list-verb error: {e}")
            print(json.dumps({"pass": False, "issues": issues}, indent=2))
            sys.exit(1)

    merged = strip_nulls(merged)

    # --- Schema validation (on the merged document) ---
    if SCHEMA_PATH.exists():
        schema = json.loads(SCHEMA_PATH.read_text())
        v = Draft202012Validator(schema)
        for e in sorted(v.iter_errors(merged), key=lambda e: list(e.path)):
            loc = "/".join(str(x) for x in e.path) or "<root>"
            add(issues, "block", f"schema:{loc}", e.message)
    else:
        add(issues, "block", "environment", f"workflow-schema.json not found: {SCHEMA_PATH}")

    # If schema already failed hard, structural assumptions below may not hold;
    # still attempt DAG checks defensively.
    nodes = merged.get("nodes") or []
    node_ids = []
    node_by_id = {}
    for i, n in enumerate(nodes):
        if not isinstance(n, dict):
            add(issues, "block", f"nodes[{i}]", "node is not a mapping")
            continue
        nid = n.get("id")
        if not nid:
            add(issues, "block", f"nodes[{i}]", "node missing id")
            continue
        if nid in node_by_id:
            add(issues, "block", f"nodes/{nid}", f"duplicate node id '{nid}'")
        node_ids.append(nid)
        node_by_id[nid] = n

    id_set = set(node_ids)

    # --- Per-node shape + ref-completeness ---
    for nid, n in node_by_id.items():
        has_use = bool(n.get("use"))
        has_agent = bool(n.get("agent"))
        has_wf = bool(n.get("workflow"))
        is_orch = n.get("delegation") == "orchestrator"
        # The three node kinds (use:/agent:/workflow:) are mutually exclusive.
        kinds = [k for k, present in
                 (("use", has_use), ("agent", has_agent), ("workflow", has_wf)) if present]
        if len(kinds) > 1:
            add(issues, "block", f"nodes/{nid}",
                f"node has more than one of use/agent/workflow ({', '.join(kinds)}); choose one")
        # A workflow: node is its own kind (an orchestrator checkpoint) — it is
        # exempt from the neither-use-nor-agent block.
        if not has_use and not has_agent and not has_wf and not is_orch:
            add(issues, "block", f"nodes/{nid}",
                "node has neither 'use' nor 'agent'; only allowed for an orchestrator-native step (delegation: orchestrator)")

        depends = n.get("depends_on") or []
        for d in depends:
            if d not in id_set:
                add(issues, "block", f"nodes/{nid}/depends_on", f"references unknown node '{d}'")

        # ${<id>.output...} in a node's own fields must be declared in depends_on.
        scoped = {k: n.get(k) for k in ("inputs", "prompt", "when", "for_each") if k in n}
        for inner in refs_in(scoped):
            for ref_id in NODE_OUTPUT_RE.findall(inner):
                if ref_id not in id_set:
                    add(issues, "block", f"nodes/{nid}", f"references output of unknown node '{ref_id}'")
                elif ref_id not in depends and ref_id != nid:
                    add(issues, "block", f"nodes/{nid}",
                        f"uses ${{{ref_id}.output...}} but '{ref_id}' is not in depends_on")

        # for_each fan-out requires an `as` binding that is a safe identifier.
        has_for_each = bool(n.get("for_each"))
        as_var = n.get("as")
        if has_for_each and not as_var:
            add(issues, "block", f"nodes/{nid}/for_each",
                "for_each requires an 'as' loop-variable name")
        if as_var and not AS_RE.match(str(as_var)):
            add(issues, "block", f"nodes/{nid}",
                f"'as' must match ^[a-z][a-z0-9_]*$ (safe identifier), got '{as_var}'")
        if as_var and not has_for_each:
            add(issues, "warn", f"nodes/{nid}", "'as' declared without 'for_each'; it has no effect")

    # --- Cycle detection over depends_on ---
    WHITE, GRAY, BLACK = 0, 1, 2
    color = {nid: WHITE for nid in id_set}

    def visit(u, stack):
        color[u] = GRAY
        for d in (node_by_id[u].get("depends_on") or []):
            if d not in color:
                continue
            if color[d] == GRAY:
                add(issues, "block", "nodes", f"dependency cycle: {' -> '.join(stack + [u, d])}")
                return
            if color[d] == WHITE:
                visit(d, stack + [u])
        color[u] = BLACK

    for nid in id_set:
        if color[nid] == WHITE:
            visit(nid, [])

    # --- Gates anchoring + id uniqueness/disjointness ---
    # Gate ids share the ${<id>.output} namespace with node ids, so they must be
    # unique among gates AND disjoint from node ids — otherwise a future feature
    # keying off a gate id (e.g. recording a human choice in results[gate.id])
    # produces an ambiguous reference.
    seen_gate_ids = set()
    for g in merged.get("gates") or []:
        if not isinstance(g, dict):
            continue
        gid = g.get("id")
        if gid:
            if gid in seen_gate_ids:
                add(issues, "block", f"gates/{gid}", f"duplicate gate id '{gid}'")
            if gid in id_set:
                add(issues, "block", f"gates/{gid}",
                    f"gate id '{gid}' collides with a node id; ids must be disjoint across nodes and gates")
            seen_gate_ids.add(gid)
        after = g.get("after")
        if after and after not in id_set:
            add(issues, "block", f"gates/{g.get('id','?')}", f"'after' references unknown node '{after}'")

    # --- Loop anchoring ---
    loop = merged.get("loop")
    if isinstance(loop, dict):
        for b in loop.get("body") or []:
            if b not in id_set:
                add(issues, "block", "loop/body", f"references unknown node '{b}'")
            elif node_by_id.get(b, {}).get("for_each"):
                add(issues, "block", "loop/body",
                    f"node '{b}' uses for_each; fan-out inside a loop body is unsupported")
        if "max_iters" not in loop:
            add(issues, "block", "loop", "missing required 'max_iters' cap")
        for inner in refs_in({"while": loop.get("while"), "carry": loop.get("carry")}):
            for ref_id in NODE_OUTPUT_RE.findall(inner):
                if ref_id not in id_set:
                    add(issues, "block", "loop", f"references output of unknown node '{ref_id}'")

    # --- output anchoring ---
    out = merged.get("output")
    if isinstance(out, dict) and out.get("from") and out["from"] not in id_set:
        add(issues, "block", "output", f"'from' references unknown node '{out['from']}'")

    # --- Nested-workflow (workflow:) resolution — only with --defs-root ---
    # LOCKED: when --defs-root is ABSENT these checks are skipped, so existing
    # single-file invocations of validate-workflow stay backward-compatible.
    wf_nodes = [(nid, n) for nid, n in node_by_id.items() if n.get("workflow")]
    if args.defs_root and wf_nodes:
        defs_root = Path(args.defs_root)
        imports_set = {imp for imp in (merged.get("imports") or []) if isinstance(imp, str)}

        # Resolve + cache every reachable child doc once (PURE: WORKFLOW.yaml only).
        child_cache = {}

        def child_doc(name):
            if name not in child_cache:
                child_cache[name] = load_child_doc(defs_root, name)
            return child_cache[name]

        for nid, n in wf_nodes:
            target = n["workflow"]
            # (a) target must be declared in the imports allowlist.
            if target not in imports_set:
                add(issues, "block", f"nodes/{nid}",
                    f"workflow: '{target}' is not listed in the top-level 'imports' allowlist")
                continue
            # (b) target must resolve to a child WORKFLOW.yaml.
            doc, err = child_doc(target)
            if doc is None:
                add(issues, "block", f"nodes/{nid}",
                    f"workflow: '{target}' {err}")
                continue
            # (c) DEPTH=1: a child that itself contains a workflow: node is a
            # grandchild nesting — hard-blocked (no dispatcher re-entrancy guard).
            gtargets = workflow_node_targets(doc)
            if gtargets:
                add(issues, "block", f"nodes/{nid}",
                    f"workflow: '{target}' itself contains a nested workflow: node "
                    f"({', '.join(sorted(set(gtargets)))}); nesting depth > 1 is not allowed")
            # (d) N4 child contract (PURE, from child WORKFLOW.yaml): every
            # required child input must be supplied by this node's inputs.
            supplied = set((n.get("inputs") or {}).keys())
            for req in sorted(required_inputs_of(doc)):
                if req not in supplied:
                    add(issues, "block", f"nodes/{nid}",
                        f"workflow: '{target}' requires input '{req}' but the node's inputs omit it")
            # (e) N4 output-shape reference: WARN (not block) when a
            # ${<nid>.output.<field>} ref names a field the child's declared output
            # node does not expose.
            child_out = doc.get("output")
            child_fields = None
            if isinstance(child_out, dict) and child_out.get("from"):
                cby = {cn.get("id"): cn for cn in (doc.get("nodes") or [])
                       if isinstance(cn, dict)}
                producer = cby.get(child_out["from"])
                if isinstance(producer, dict):
                    osch = producer.get("output_schema")
                    if isinstance(osch, dict) and isinstance(osch.get("properties"), dict):
                        child_fields = set(osch["properties"].keys())
            if child_fields is not None:
                pat = re.compile(r"\b" + re.escape(nid) + r"\.output\.([a-zA-Z0-9_]+)")
                for other_id, other in node_by_id.items():
                    refsrc = {k: other.get(k) for k in
                              ("inputs", "prompt", "when", "for_each") if k in other}
                    for s in collect_strings(refsrc):
                        for fld in pat.findall(s):
                            if fld not in child_fields:
                                add(issues, "warn", f"nodes/{other_id}",
                                    f"references ${{{nid}.output.{fld}}} but child workflow "
                                    f"'{target}' output does not declare field '{fld}'")

        # (f) Import-cycle DFS over the IMPORT graph reachable from this workflow.
        # 3-color: a GRAY back-edge is a cycle. Adjacency = a doc's workflow: targets
        # restricted to its own imports allowlist (only resolvable children).
        root_name = merged.get("name")
        IWHITE, IGRAY, IBLACK = 0, 1, 2
        icolor = {}

        def doc_imports(doc):
            return {imp for imp in (doc.get("imports") or []) if isinstance(imp, str)}

        def ivisit(name, doc, stack):
            icolor[name] = IGRAY
            allow = doc_imports(doc)
            for tgt in workflow_node_targets(doc):
                if tgt not in allow:
                    continue  # already reported as not-in-imports for the root
                if icolor.get(tgt) == IGRAY:
                    add(issues, "block", "imports",
                        f"workflow import cycle: {' -> '.join(stack + [name, tgt])}")
                    continue
                if icolor.get(tgt, IWHITE) == IWHITE:
                    cdoc, _ = child_doc(tgt)
                    if cdoc is not None:
                        ivisit(tgt, cdoc, stack + [name])
            icolor[name] = IBLACK

        if root_name:
            ivisit(root_name, merged, [])

    passed = not any(i["severity"] == "block" for i in issues)
    print(json.dumps({"pass": passed, "issues": issues}, indent=2))
    sys.exit(0 if passed else 1)


if __name__ == "__main__":
    main()

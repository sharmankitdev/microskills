#!/usr/bin/env python3
"""
resolve-microskill — deterministic profile resolver + runtime config preflight.

Loads a microskill's default + named-profile config, applies dotted-path
overrides, validates against the JSON Schema, substitutes {{key}} placeholders
in SKILL.md from `vars`, resolves `inputs.inject_from` sources, applies
`steps.<n>.optional` / `mandate_tool`, gathers `context.refs/snippets/extend`,
and emits a single JSON document on stdout describing the resolved state
plus a rendered SKILL.md body ready for the LLM to execute.

Usage:
  resolve-microskill <skill-name> [--profile <name>]
                                  [--override <dotted.path=value>]...
                                  [--skip-step <n>]...
                                  [--skill-root <dir>]
                                  [--inject-only | --skip-inject]

`--inject-only` resolves the profile config, executes ONLY the env-dependent
`inputs.<name>.inject_from` sources, and emits {skill_name, profile_used,
profile_requested, warnings, injected_inputs} — no body rendering. It is the
execution-time companion of compile-workflow's frozen resolver payloads
(.compiled/resolved/<node-id>.json), which exclude injected_inputs so the
compile closure stays env-independent.

`--skip-inject` is the COMPILE-TIME mode (compile-workflow / validate-workflow
pass it): inject_from sources are never EXECUTED — no env reads, no git config,
no arbitrary `command:` shell in the compile path — so resolution is
side-effect-free and cannot fail (or vary) on the compile machine's env.
injected_inputs is {} by construction; the execution-time `--inject-only` call
applies the sources for real. Mutually exclusive with `--inject-only`.

The required-input ledger (`required_inputs`, `profile_overrides_inputs`, and
the rewritten Inputs table) is computed from DECLARED `inject_from` presence,
never from inject success: a declared-inject input is supplied by the
execution environment (or `--inject-only` fails loud there), so it is never
caller-gathered — and the emitted payload shape is a pure function of registry
bytes + profile, regardless of the resolving machine's env.

Stdout: JSON (see README / config-schema doc for the shape).
Exit codes: 0 OK · 1 block · 2 environment / script error.
"""

import argparse
import importlib.machinery
import importlib.util
import json
import os
import re
import subprocess
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print(json.dumps({"error": "PyYAML not installed. pip3 install pyyaml"}))
    sys.exit(2)

try:
    from jsonschema import Draft202012Validator
except ImportError:
    print(json.dumps({"error": "jsonschema not installed. pip3 install jsonschema"}))
    sys.exit(2)

SCRIPT = Path(__file__).resolve()
PROJECT_ROOT = SCRIPT.parents[2]
DEFAULT_SKILL_ROOT = PROJECT_ROOT / ".claude" / "microskills"


def _templates_root(script):
    """Locate templates/ (schemas + component templates).

    When MICROSKILLS_TEMPLATES_ROOT is set it wins outright — an explicit pin used
    by hermetic tests (and any caller) to bind the canonical catalog templates/
    instead of a possibly-stale generated mirror. When unset, behavior is
    unchanged: prefer the materialized runtime copy under .claude/, then
    ${CLAUDE_PLUGIN_ROOT}, then the in-repo dogfood source."""
    pin = os.environ.get("MICROSKILLS_TEMPLATES_ROOT")
    if pin:
        return Path(pin)
    proj = script.parents[2]
    cands = [proj / ".claude" / "templates"]
    env = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if env:
        cands.append(Path(env) / "templates")
    cands.append(proj / "templates")
    return next((c for c in cands if c.is_dir()), cands[0])


SCHEMA_PATH = _templates_root(SCRIPT) / "references" / "config-schema.json"

# Shared linear-path vocabulary (STEP_RE / BRANCH_RE / STEP_CAP). The SAME module
# backs validate-microskill's author-time lint, so a profile that adds/patches a
# step cannot smuggle branching language past a check the validator would catch.
# Loaded via SourceFileLoader to match the engine's extension-less-script pattern.
_STEPS_MOD_PATH = SCRIPT.parent / "microskill_steps.py"
_steps_loader = importlib.machinery.SourceFileLoader(
    "microskill_steps", str(_STEPS_MOD_PATH)
)
_steps_spec = importlib.util.spec_from_loader("microskill_steps", _steps_loader)
microskill_steps = importlib.util.module_from_spec(_steps_spec)
_steps_loader.exec_module(microskill_steps)

PLACEHOLDER_RE = re.compile(r"\{\{([\w-]+)\}\}")
STEP_LINE_RE = re.compile(r"^(\d+)\.\s", re.MULTILINE)
INPUTS_HEADER_RE = re.compile(r"^\s*\|\s*Name\s*\|", re.IGNORECASE)
INPUTS_SEP_RE = re.compile(r"^\s*\|[-| :]+\|\s*$")
GATE_AFTER_STEP_RE = re.compile(r"^(?:step_)?(\d+)$")
GATE_ID_COMMENT_RE = re.compile(r"<!--\s*gate-id:\s*([a-z][a-z0-9_-]*)\s*-->")


LIST_VERBS = ("add", "patch", "remove")


def apply_list_verbs(base_list, verbs, key="id", path=""):
    """Apply id-addressable add/patch/remove verbs to a list-of-objects, returning
    a NEW list (the input is never mutated).

    Order is REMOVE -> PATCH -> ADD:
      - remove: drop the base entry whose [key] == id, for each id in verbs['remove'].
        A missing id is an error (it names something that isn't there).
      - patch: for each object (carrying a [key]) in verbs['patch'], find the entry
        by id and deep_merge the patch INTO it, preserving its position. Missing id -> error.
      - add: append each object in verbs['add'] in order. An id that already exists
        (after removes) is a collision error.

    Entries without a [key] cannot be addressed; a verb referencing a missing id
    already raises, so unaddressable entries simply survive untouched.
    """
    where = f" at '{path}'" if path else ""

    def find_index(entries, target_id):
        for i, e in enumerate(entries):
            if isinstance(e, dict) and e.get(key) == target_id:
                return i
        return None

    result = [dict(e) if isinstance(e, dict) else e for e in base_list]

    for rid in verbs.get("remove", []) or []:
        idx = find_index(result, rid)
        if idx is None:
            raise ValueError(
                f"list-verb remove{where}: no entry with {key}={rid!r} to remove"
            )
        result.pop(idx)

    for patch in verbs.get("patch", []) or []:
        pid = patch.get(key) if isinstance(patch, dict) else None
        idx = find_index(result, pid)
        if idx is None:
            raise ValueError(
                f"list-verb patch{where}: no entry with {key}={pid!r} to patch"
            )
        result[idx] = deep_merge(result[idx], patch, path)

    for add in verbs.get("add", []) or []:
        aid = add.get(key) if isinstance(add, dict) else None
        if find_index(result, aid) is not None:
            raise ValueError(
                f"list-verb add{where}: entry with {key}={aid!r} already exists (collision)"
            )
        result.append(add)

    return result


def deep_merge(base, overlay, path=""):
    if not isinstance(base, dict) or not isinstance(overlay, dict):
        return overlay
    result = dict(base)
    for k, v in overlay.items():
        cur_path = f"{path}.{k}" if path else k
        if v is None:
            result.pop(k, None)
            continue
        if k in result:
            if isinstance(result[k], list) and isinstance(v, dict) and v:
                # An overlay dict over a base list is the id-addressable list-verb
                # form: {add:[...], patch:[...], remove:[ids]}. A non-empty dict whose
                # keys are a subset of the verb set routes to apply_list_verbs (runs
                # INSIDE the merge, before --override / strip_nulls, so REMOVE never
                # fights the null-delete key-pop above). A dict carrying any non-verb
                # key cannot meaningfully merge onto a list -> error. An EMPTY dict is
                # not a verb dict and falls through to the legacy replace branch below.
                if set(v.keys()) <= set(LIST_VERBS):
                    result[k] = apply_list_verbs(result[k], v, path=cur_path)
                    continue
                raise ValueError(
                    f"cannot merge dict with non-verb keys onto list at '{cur_path}': "
                    f"{sorted(v.keys())} (allowed verbs: {sorted(LIST_VERBS)})"
                )
            if cur_path == "output_schema":
                # output_schema is a contract, not a knob: an overlay replaces it
                # wholesale (never a recursive properties-merge that would let base
                # fields leak into a profile's intended shape). Absence in the
                # overlay leaves base's output_schema untouched (the fallback).
                result[k] = v
            elif isinstance(result[k], dict) and isinstance(v, dict):
                result[k] = deep_merge(result[k], v, cur_path)
            elif isinstance(result[k], list) and isinstance(v, list):
                if cur_path == "gates.add":
                    result[k] = result[k] + v
                else:
                    result[k] = v
            else:
                result[k] = v
        else:
            result[k] = v
    return result


def parse_override_value(raw_value):
    """Parse a --override value per the CLI contract: YAML for typed values
    (`true` -> bool, `3` -> int, `[a,b]` -> list), empty string -> None (delete).

    PAPER-CUT FIX: a value LEADING with '#' is taken as the LITERAL STRING. An
    unquoted leading-'#' value is a full-line YAML comment — yaml.safe_load
    returns None, silently turning `--override tag=#smoke` into a key DELETE.
    No expressible value changes meaning (a bare '#...' could never parse to
    anything but None), so the literal reading only closes the silent-delete
    hole. Shared by resolve-microskill --override AND compile-workflow's
    customize.overrides / --node-override (one parser, one semantics)."""
    if raw_value == "":
        return None
    if raw_value.lstrip().startswith("#"):
        return raw_value
    return yaml.safe_load(raw_value)


def apply_override(cfg, dotted, raw_value):
    parsed = parse_override_value(raw_value)
    keys = [k for k in dotted.split(".") if k]
    if not keys:
        raise ValueError(f"empty override path: {dotted!r}")
    cur = cfg
    for k in keys[:-1]:
        if k not in cur or not isinstance(cur[k], dict):
            cur[k] = {}
        cur = cur[k]
    if parsed is None:
        cur.pop(keys[-1], None)
    else:
        cur[keys[-1]] = parsed


def strip_nulls(obj):
    if isinstance(obj, dict):
        return {k: strip_nulls(v) for k, v in obj.items() if v is not None}
    if isinstance(obj, list):
        return [strip_nulls(x) for x in obj]
    return obj


def split_frontmatter(text):
    if not text.startswith("---\n"):
        return None, text
    end = text.find("\n---\n", 4)
    if end == -1:
        return None, text
    return text[4:end], text[end + 5:]


def substitute_vars(text, vars_map, unresolved):
    def repl(m):
        k = m.group(1)
        if k in vars_map:
            return str(vars_map[k])
        if k not in unresolved:
            unresolved.append(k)
        return m.group(0)
    return PLACEHOLDER_RE.sub(repl, text)


def resolve_inject_from(input_name, spec, config_dir, warnings):
    if "env" in spec:
        var = spec["env"]
        val = os.environ.get(var, "")
        if not val:
            warnings.append(f"input '{input_name}': env var '{var}' is unset or empty")
            return None
        return val
    if "git_config" in spec:
        key = spec["git_config"]
        try:
            proc = subprocess.run(
                ["git", "config", key], cwd=str(config_dir),
                capture_output=True, text=True,
            )
        except FileNotFoundError:
            warnings.append(f"input '{input_name}': git not available on PATH")
            return None
        if proc.returncode != 0 or not proc.stdout.strip():
            warnings.append(f"input '{input_name}': git config '{key}' returned no value")
            return None
        return proc.stdout.strip()
    if "file" in spec:
        path = config_dir / spec["file"]
        try:
            return path.read_text().strip()
        except (FileNotFoundError, PermissionError) as e:
            warnings.append(f"input '{input_name}': file '{spec['file']}' not readable ({e})")
            return None
    if "command" in spec:
        cmd = spec["command"]
        try:
            proc = subprocess.run(
                cmd, shell=True, cwd=str(config_dir),
                capture_output=True, text=True,
            )
        except Exception as e:
            warnings.append(f"input '{input_name}': command '{cmd}' failed: {e}")
            return None
        if proc.returncode != 0:
            warnings.append(
                f"input '{input_name}': command '{cmd}' exited with code "
                f"{proc.returncode}: {proc.stderr.strip()}"
            )
            return None
        out = proc.stdout.strip()
        if not out:
            warnings.append(f"input '{input_name}': command '{cmd}' produced no output")
            return None
        return out
    warnings.append(f"input '{input_name}': inject_from has no recognized source key")
    return None


def parse_inputs_table(body):
    m = re.search(r"(?m)^## Inputs\s*$", body)
    if not m:
        return {}
    start = m.end()
    after = re.search(r"(?m)^## ", body[start:])
    section = body[start: start + after.start()] if after else body[start:]
    out = {}
    for line in section.splitlines():
        stripped = line.strip()
        if not stripped.startswith("|"):
            continue
        if INPUTS_HEADER_RE.match(line):
            continue
        if INPUTS_SEP_RE.match(line):
            continue
        parts = line.split("|")
        if len(parts) < 7:
            continue
        name = parts[1].strip()
        if not name:
            continue
        out[name] = {
            "required_col": parts[2].strip(),
            "default_col": parts[5].strip(),
        }
    return out


def rewrite_inputs_table(body, profile_overrides_inputs, base_defaults=None):
    base_defaults = base_defaults or {}
    if not profile_overrides_inputs and not base_defaults:
        return body
    m = re.search(r"(?m)^## Inputs\s*$", body)
    if not m:
        return body
    start = m.end()
    after = re.search(r"(?m)^## ", body[start:])
    section_end = start + after.start() if after else len(body)
    section = body[start:section_end]
    out_chunks = []
    for line in section.splitlines(keepends=True):
        stripped = line.rstrip("\n")
        if (not stripped.strip().startswith("|")
                or INPUTS_HEADER_RE.match(stripped)
                or INPUTS_SEP_RE.match(stripped)):
            out_chunks.append(line)
            continue
        parts = stripped.split("|")
        if len(parts) < 7:
            out_chunks.append(line)
            continue
        name = parts[1].strip()
        if name in profile_overrides_inputs:
            parts[2] = " yes "
            parts[5] = " — "
            new_line = "|".join(parts)
        elif name in base_defaults:
            parts[5] = f" {base_defaults[name]} "
            new_line = "|".join(parts)
        else:
            out_chunks.append(line)
            continue
        if line.endswith("\n"):
            new_line += "\n"
        out_chunks.append(new_line)
    return body[:start] + "".join(out_chunks) + body[section_end:]


def parse_steps_section(body):
    m = re.search(r"(?m)^## Steps\s*$", body)
    if not m:
        return body, None, ""
    start = m.end()
    after_match = re.search(r"(?m)^## ", body[start:])
    if after_match:
        block_end = start + after_match.start()
        return body[: m.start()], body[m.start():block_end], body[block_end:]
    return body[: m.start()], body[m.start():], ""


def enumerate_steps(steps_block):
    if not steps_block:
        return []
    starts = [(m.start(), int(m.group(1))) for m in STEP_LINE_RE.finditer(steps_block)]
    out = []
    for i, (s, n) in enumerate(starts):
        e = starts[i + 1][0] if i + 1 < len(starts) else len(steps_block)
        out.append((s, e, n))
    return out


def parse_gate_after_step(after_val):
    """Return original step number for step-anchored `after`, else None."""
    if after_val is None:
        return None
    m = GATE_AFTER_STEP_RE.match(str(after_val).strip())
    return int(m.group(1)) if m else None


class StepDirectiveError(ValueError):
    """A steps.add/patch/remove directive referenced a step that does not exist,
    or introduced disallowed branching language. Surfaced as a clean JSON error."""


def apply_step_directives(body, cfg, skip_steps, warnings):
    """Restructure, renumber, skip, and annotate the Steps section.

    Profile step directives (keyed by ORIGINAL step number) are applied
    REMOVE -> PATCH -> ADD, then the surviving + added steps are renumbered
    contiguously by the same counter loop that handles --skip-step. A step
    removed via steps.remove participates in the SAME gate-anchor fallback as a
    skipped step (MUST-FIX #3): a gate anchored after it falls back to the
    trailing 'Gates (resolved)' block rather than silently vanishing.

    Returns (rendered_body, inline_gate_ids: set[str]) so the trailing
    `## Gates (resolved)` block can skip gates already emitted inline.

    Raises StepDirectiveError if a patch/remove names a missing original step,
    or an add anchors after an absent original step.
    """
    before, steps_block, after = parse_steps_section(body)
    if steps_block is None:
        return body, set()
    steps = enumerate_steps(steps_block)
    if not steps:
        return body, set()

    steps_cfg = cfg.get("steps") or {}
    runtime_cfg = cfg.get("runtime") or {}
    allowed_tools = runtime_cfg.get("allowed_tools") or []
    allowed_mcps = runtime_cfg.get("allowed_mcps") or []
    inputs_cfg = cfg.get("inputs") or {}
    snippets = (cfg.get("context") or {}).get("snippets") or []
    gates_cfg = cfg.get("gates") or {}
    gates_add = gates_cfg.get("add") or []

    existing_step_numbers = {n for (_, _, n) in steps}

    # --- steps.remove / steps.patch / steps.add directives (keyed by ORIGINAL n) ---
    remove_list = steps_cfg.get("remove") or []
    patch_map = steps_cfg.get("patch") or {}
    add_list = steps_cfg.get("add") or []

    removed = set()
    for rn in remove_list:
        if rn not in existing_step_numbers:
            raise StepDirectiveError(
                f"steps.remove: step {rn} does not exist in MICROSKILL.md"
            )
        removed.add(rn)

    patch_text = {}
    for key, spec in patch_map.items():
        try:
            pn = int(key)
        except (TypeError, ValueError):
            raise StepDirectiveError(f"steps.patch: non-numeric step key {key!r}")
        if pn not in existing_step_numbers:
            raise StepDirectiveError(
                f"steps.patch: step {pn} does not exist in MICROSKILL.md"
            )
        if pn in removed:
            raise StepDirectiveError(
                f"steps.patch: step {pn} was removed by steps.remove; cannot patch"
            )
        patch_text[pn] = (spec or {}).get("text") or ""

    # ADD anchors resolve against the SURVIVING original step numbers (post-remove)
    # plus 0 (prepend). Preserve declared order for adds sharing an anchor.
    surviving_numbers = existing_step_numbers - removed
    adds_after = {}  # original-anchor -> [text, ...]
    for entry in add_list:
        anchor = (entry or {}).get("after")
        text = (entry or {}).get("text") or ""
        if anchor != 0 and anchor not in surviving_numbers:
            raise StepDirectiveError(
                f"steps.add: anchor 'after: {anchor}' names no surviving step in MICROSKILL.md"
            )
        adds_after.setdefault(anchor, []).append(text)

    # --- step-anchored gate bookkeeping ---
    step_anchored_gates = {}
    for g in gates_add:
        n_orig = parse_gate_after_step(g.get("after"))
        if n_orig is not None:
            step_anchored_gates.setdefault(n_orig, []).append({
                "id": g["id"],
                "severity": g.get("severity", "hard"),
            })

    valid_skips = set()
    for n in skip_steps:
        scfg = (steps_cfg.get(str(n)) or {}) if steps_cfg else {}
        if scfg.get("optional"):
            valid_skips.add(n)
        else:
            warnings.append(
                f"--skip-step {n} ignored: step {n} is not marked optional in config"
            )

    # A step elided either by --skip-step OR steps.remove drops out of the
    # renumbered body; both MUST trigger the gate-anchor fallback (MUST-FIX #3).
    elided = valid_skips | removed

    inline_gate_ids = set()
    for n_orig in list(step_anchored_gates.keys()):
        if n_orig in elided:
            reason = (
                "removed step" if n_orig in removed else "skipped step"
            )
            for g in step_anchored_gates[n_orig]:
                warnings.append(
                    f"gate '{g['id']}' anchored after {reason} {n_orig}; "
                    f"falling back to trailing 'Gates (resolved)' block"
                )
            del step_anchored_gates[n_orig]
        elif n_orig not in existing_step_numbers:
            for g in step_anchored_gates[n_orig]:
                warnings.append(
                    f"gate '{g['id']}' anchored after step {n_orig} which does not exist in MICROSKILL.md; "
                    f"falling back to trailing 'Gates (resolved)' block"
                )
            del step_anchored_gates[n_orig]

    head = steps_block[: steps[0][0]]
    counter = 0
    out_chunks = []

    def emit_added(anchor):
        """Render any steps added after `anchor` (original number, or 0 for prepend)."""
        nonlocal counter
        for text in adds_after.get(anchor, []):
            counter += 1
            out_chunks.append(f"{counter}. {text}\n")

    # prepended adds (after: 0) land before the first surviving step
    emit_added(0)

    for (s, e, n) in steps:
        if n in elided:
            continue
        counter += 1
        chunk = steps_block[s:e]
        if n in patch_text:
            # PATCH replaces the body wholesale, keeping the renumbered prefix.
            chunk = f"{counter}. {patch_text[n]}\n"
        else:
            chunk = re.sub(r"^\d+\.\s", f"{counter}. ", chunk, count=1)
        scfg = (steps_cfg.get(str(n)) or {}) if steps_cfg else {}

        tags = []
        tool = scfg.get("mandate_tool")
        if tool:
            tags.append(f"[REQUIRED TOOL: {tool}]")
        if allowed_tools:
            tags.append(f"[ALLOWED TOOLS: {', '.join(allowed_tools)}]")
        if allowed_mcps:
            tags.append(f"[ALLOWED MCPs: {', '.join(allowed_mcps)}]")
        for in_name, in_spec in inputs_cfg.items():
            allowed = (in_spec or {}).get("allowed_values") or []
            if not allowed:
                continue
            if re.search(rf"\b{re.escape(in_name)}\b", chunk):
                tags.append(f"[INPUT {in_name} ∈ {'|'.join(allowed)}]")
                warnings.append(
                    f"heuristic match: input '{in_name}' allowed_values echoed on step {counter}"
                )
        for snip in snippets:
            name = (snip or {}).get("name") or ""
            if not name:
                continue
            if re.search(rf"\b{re.escape(name)}\b", chunk):
                tags.append(f"[CITE SNIPPET: {name}]")
                warnings.append(
                    f"heuristic match: snippet '{name}' citation hint added on step {counter}"
                )
        if tags:
            tag_str = " ".join(tags)
            chunk = re.sub(
                rf"^{counter}\.\s",
                f"{counter}. {tag_str} ",
                chunk, count=1,
            )

        if n in step_anchored_gates:
            gate_lines = [
                f"   [GATE AFTER STEP {counter}: {g['id']} (severity: {g['severity']})]"
                for g in step_anchored_gates[n]
            ]
            for g in step_anchored_gates[n]:
                inline_gate_ids.add(g["id"])
            first_nl = chunk.find("\n")
            insertion = "\n" + "\n".join(gate_lines) + "\n"
            if first_nl == -1:
                chunk = chunk + insertion
            else:
                chunk = chunk[: first_nl + 1] + insertion + chunk[first_nl + 1:]

        out_chunks.append(chunk)

        # adds anchored after this ORIGINAL step land immediately after it
        emit_added(n)

    return before + head + "".join(out_chunks) + after, inline_gate_ids


def build_context_block(context_cfg, config_dir, vars_map, unresolved, warnings):
    parts = []
    refs = context_cfg.get("refs") or []
    if refs:
        missing = [r for r in refs if not (config_dir / r).exists()]
        for m in missing:
            warnings.append(f"context.refs path not found: {m}")
        if missing:
            return None
        parts.append("### References (read before starting)")
        for r in refs:
            parts.append(f"- {r}")
        parts.append("")
    snippets = context_cfg.get("snippets") or []
    if snippets:
        parts.append("### Snippets")
        for s in snippets:
            txt = substitute_vars(s["text"], vars_map, unresolved)
            parts.append(f"- **{s['name']}**: {txt}")
        parts.append("")
    extend = context_cfg.get("extend")
    if extend:
        epath = config_dir / extend
        if not epath.exists():
            warnings.append(f"context.extend path not found: {extend}")
            return None
        parts.append("### Extended context (revise in place)")
        parts.append(f"Source path: `{extend}`")
        parts.append("")
        parts.append(epath.read_text())
        parts.append("")
    return "\n".join(parts)


def build_gates_directive(gates_cfg):
    out = []
    for key, val in gates_cfg.items():
        if key == "add":
            continue
        entry = {"id": key}
        if val and "severity" in val:
            entry["severity"] = val["severity"]
        out.append(entry)
    for added in gates_cfg.get("add", []) or []:
        out.append({
            "id": added["id"],
            "after": added.get("after"),
            "type": added.get("type"),
            "prompt": added.get("prompt"),
            "severity": added.get("severity", "hard"),
        })
    return out


def render_gates_block(gates_list, inline_gate_ids=None):
    inline_gate_ids = inline_gate_ids or set()
    visible = [g for g in gates_list if g["id"] not in inline_gate_ids]
    if not visible:
        return ""
    lines = ["", "## Gates (resolved)", ""]
    for g in visible:
        line = f"- **{g['id']}** (severity: {g.get('severity', 'hard')})"
        if g.get("after"):
            line += f" — fires after `{g['after']}`"
        if g.get("type"):
            line += f", type: `{g['type']}`"
        if g.get("prompt"):
            line += f". Prompt: {g['prompt']!r}"
        lines.append(line)
    lines.append("")
    return "\n".join(lines)


def emit_and_exit(payload, code):
    print(json.dumps(payload, indent=2))
    sys.exit(code)


def main():
    ap = argparse.ArgumentParser(
        description="Resolve a microskill's profile config and render its SKILL.md.",
    )
    ap.add_argument("skill", help="Skill name (subdir under --skill-root).")
    ap.add_argument("--profile", default=None,
                    help="Profile name. Resolved from base.profile.default if omitted; falls back to base alone.")
    ap.add_argument("--override", action="append", default=[],
                    help="Dotted-path override 'a.b.c=value'. Repeatable.")
    ap.add_argument("--skip-step", action="append", default=[], type=int,
                    help="Skip an optional step by number. Repeatable.")
    ap.add_argument("--skill-root", default=str(DEFAULT_SKILL_ROOT),
                    help="Override skill-root directory.")
    ap.add_argument("--inject-only", action="store_true",
                    help="Resolve the profile config, execute ONLY the inject_from "
                         "sources, and emit the injected_inputs (no body rendering). "
                         "Execution-time companion of compile-workflow's frozen "
                         "resolver payloads, which exclude env-dependent inject results.")
    ap.add_argument("--skip-inject", action="store_true",
                    help="Never EXECUTE inject_from sources (compile-time mode: the "
                         "compile path must be side-effect-free and the frozen "
                         "payload env-independent). injected_inputs is {} and an "
                         "unsatisfiable source cannot block; --inject-only applies "
                         "the sources at execution time instead.")
    args = ap.parse_args()

    if args.inject_only and args.skip_inject:
        emit_and_exit({"error": "--inject-only and --skip-inject are mutually "
                                "exclusive (execute-the-sources vs never-execute)"}, 2)

    skill_root = Path(args.skill_root).resolve()
    skill_dir = skill_root / args.skill

    if not skill_dir.is_dir():
        sys.stderr.write(f"skill directory not found: {skill_dir}\n")
        emit_and_exit({"error": f"skill directory not found: {skill_dir}"}, 2)

    warnings = []

    profiles_dir = skill_dir / "profiles"
    base_path = profiles_dir / "base.yaml"
    # An ABSENT profiles/base.yaml resolves with an empty overlay (mirrors
    # compile-workflow's already-tolerant base handling) rather than erroring;
    # version is defaulted to 1 below so the MICROSKILL.md-derived config is still
    # schema-validated (not silently skipped).
    if base_path.exists():
        try:
            cfg = yaml.safe_load(base_path.read_text()) or {}
        except yaml.YAMLError as e:
            sys.stderr.write(f"base.yaml parse error: {e}\n")
            emit_and_exit({"error": f"base.yaml parse error: {e}"}, 1)
    else:
        cfg = {}

    base_default_profile = (cfg.get("profile") or {}).get("default")
    if args.profile is not None:
        effective_profile = args.profile
    elif base_default_profile:
        effective_profile = base_default_profile
    else:
        effective_profile = "base"

    profile_used = effective_profile
    if effective_profile != "base":
        overlay_path = profiles_dir / f"{effective_profile}.yaml"
        if overlay_path.exists():
            try:
                overlay_cfg = yaml.safe_load(overlay_path.read_text()) or {}
            except yaml.YAMLError as e:
                sys.stderr.write(f"profile '{effective_profile}' parse error: {e}\n")
                emit_and_exit({"error": f"profile '{effective_profile}' parse error: {e}"}, 1)
            if "profile" in overlay_cfg:
                sys.stderr.write(
                    f"profile '{effective_profile}': 'profile' block is only allowed in base.yaml\n"
                )
                emit_and_exit({
                    "error": f"profile '{effective_profile}': 'profile' block is only allowed in base.yaml"
                }, 1)
            overlay_default_inputs = [
                name for name, spec in (overlay_cfg.get("inputs") or {}).items()
                if isinstance(spec, dict) and "default" in spec
            ]
            if overlay_default_inputs:
                sys.stderr.write(
                    f"profile '{effective_profile}': inputs.<name>.default is base-only "
                    f"(overlays must not redeclare); found in: {overlay_default_inputs}\n"
                )
                emit_and_exit({
                    "error": f"profile '{effective_profile}': inputs.<name>.default is base-only; found in: {overlay_default_inputs}"
                }, 1)
            try:
                cfg = deep_merge(cfg, overlay_cfg)
            except ValueError as e:
                sys.stderr.write(f"profile '{effective_profile}' list-verb error: {e}\n")
                emit_and_exit({
                    "error": f"profile '{effective_profile}' list-verb error: {e}"
                }, 1)
        else:
            warnings.append(
                f"profile '{effective_profile}' not found at profiles/{effective_profile}.yaml; using base"
            )
            profile_used = "base"

    for ov in args.override:
        if "=" not in ov:
            sys.stderr.write(f"malformed --override (no '='): {ov}\n")
            emit_and_exit({
                "warnings": warnings + [f"malformed --override: {ov}"],
                "error": "override must be in form 'dotted.path=value'",
            }, 1)
        path, _, val = ov.partition("=")
        try:
            apply_override(cfg, path.strip(), val.strip())
        except Exception as e:
            sys.stderr.write(f"override apply failed: {e}\n")
            emit_and_exit({"error": f"override apply failed: {e}"}, 1)

    cfg = strip_nulls(cfg)

    # An OMITTED version defaults to 1 BEFORE schema validation, so a base.yaml
    # (or an absent base.yaml) that does not declare version still resolves. The
    # const:1 check stays intact, so an EXPLICIT wrong version still blocks. This
    # also makes an empty {} config non-empty, so the schema check below is NOT
    # silently skipped for a microskill with no base.yaml.
    cfg.setdefault("version", 1)

    if cfg and not SCHEMA_PATH.exists():
        emit_and_exit({"error": f"config-schema.json not found: {SCHEMA_PATH}"}, 1)

    if cfg:
        schema = json.loads(SCHEMA_PATH.read_text())
        v = Draft202012Validator(schema)
        errs = sorted(v.iter_errors(cfg), key=lambda e: list(e.path))
        if errs:
            for e in errs:
                p = "/".join(str(x) for x in e.path) or "<root>"
                msg = f"schema {p}: {e.message}"
                warnings.append(msg)
                sys.stderr.write(msg + "\n")
            emit_and_exit({
                "skill_name": args.skill,
                "profile_used": profile_used,
                "profile_requested": args.profile,
                "warnings": warnings,
                "config": cfg,
            }, 1)

    vars_map = cfg.get("vars") or {}

    injected_inputs = {}
    inject_failed = False
    # --skip-inject: compile-time resolution never EXECUTES inject sources
    # (env reads, git config, arbitrary `command:` shell are execution-time
    # concerns — see --inject-only); the payload below is independent of
    # whether the compile machine's env could satisfy them.
    if not args.skip_inject:
        for name, spec in (cfg.get("inputs") or {}).items():
            inj = (spec or {}).get("inject_from")
            if not inj:
                continue
            val = resolve_inject_from(name, inj, skill_dir, warnings)
            if val is None:
                inject_failed = True
            else:
                injected_inputs[name] = val

    # --inject-only: emit ONLY the env-dependent inject results and stop. The
    # compile-time freeze (compile-workflow) excludes injected_inputs from the
    # frozen resolver payload so the compile closure stays env-independent; this
    # mode re-applies the inject_from sources at execution time. No body
    # rendering — the frozen payload already carries rendered_skill_body.
    if args.inject_only:
        emit_and_exit({
            "skill_name": args.skill,
            "profile_used": profile_used,
            "profile_requested": args.profile,
            "warnings": warnings,
            "injected_inputs": injected_inputs,
        }, 1 if inject_failed else 0)

    skill_md = skill_dir / "MICROSKILL.md"
    if not skill_md.exists():
        sys.stderr.write(f"MICROSKILL.md not found: {skill_md}\n")
        emit_and_exit({"error": f"MICROSKILL.md not found: {skill_md}"}, 2)
    full = skill_md.read_text()
    _, body = split_frontmatter(full)

    unresolved = []
    rendered = substitute_vars(body, vars_map, unresolved)

    skill_md_inputs = parse_inputs_table(body)
    required_inputs = []
    profile_overrides_inputs = {}
    for name, spec in (cfg.get("inputs") or {}).items():
        if not (spec or {}).get("required"):
            continue
        if name not in skill_md_inputs:
            warnings.append(
                f"input '{name}': declared required in config but not found in MICROSKILL.md Inputs table"
            )
            continue
        # DECLARED inject_from presence — never inject SUCCESS — excludes an
        # input from the caller-gathered ledger: the value comes from the
        # execution environment (a failed source fails loud there via exit 1 /
        # --inject-only). Keying this off injected_inputs made required_inputs,
        # profile_overrides_inputs, and the rewritten Inputs table depend on
        # the resolving machine's env — and leaked env into compile-workflow's
        # frozen payloads (different bytes, different manifest_hash, same def).
        if (spec or {}).get("inject_from"):
            continue
        required_inputs.append(name)
        if skill_md_inputs[name]["required_col"].lower() != "yes":
            profile_overrides_inputs[name] = {
                "required": True,
                "default_nullified": True,
            }
    base_defaults = {
        name: spec["default"]
        for name, spec in (cfg.get("inputs") or {}).items()
        if isinstance((spec or {}).get("default"), str)
    }
    rendered = rewrite_inputs_table(rendered, profile_overrides_inputs, base_defaults)

    try:
        rendered, inline_gate_ids = apply_step_directives(
            rendered,
            cfg,
            args.skip_step,
            warnings,
        )
    except StepDirectiveError as e:
        sys.stderr.write(f"step directive error: {e}\n")
        emit_and_exit({"error": f"step directive error: {e}"}, 1)

    # Atomicity re-check on the MERGED Steps (LOCKED decision: inline, shared
    # module). A profile add/patch could introduce branching language the
    # author-time validator never saw; reject it with the SAME BRANCH_RE the
    # validator uses. The >STEP_CAP cap stays an advisory WARN (not a block),
    # consistent with validate-microskill's documented advisory cap.
    _, merged_steps_block, _ = parse_steps_section(rendered)
    if merged_steps_block:
        branch_hits = microskill_steps.find_branch_language(merged_steps_block)
        if branch_hits:
            snippet, _span = branch_hits[0]
            sys.stderr.write(
                f"merged steps introduce branching language: \"…{snippet}…\"\n"
            )
            emit_and_exit({
                "error": (
                    f"profile step directive introduced branching language into the "
                    f"merged Steps — microskills must form a single linear path "
                    f"(no branches, conditionals, loops): \"…{snippet}…\""
                )
            }, 1)
        merged_count = microskill_steps.count_steps(merged_steps_block)
        if merged_count > microskill_steps.STEP_CAP:
            warnings.append(
                f"{merged_count} merged numbered steps; consider whether this is "
                f"still one atomic task"
            )

    gates_cfg = cfg.get("gates") or {}
    declared_gate_ids = set(GATE_ID_COMMENT_RE.findall(body))
    add_ids = [(g or {}).get("id") for g in (gates_cfg.get("add") or [])]
    collisions = [gid for gid in add_ids if gid in declared_gate_ids]
    if collisions:
        sys.stderr.write(
            f"gates.add[].id collision with skill-declared gate id(s): {collisions}\n"
        )
        emit_and_exit({
            "error": f"gates.add[].id collision with skill-declared gate id(s): {collisions}"
        }, 1)
    seen_add_ids = set()
    duplicate_add_ids = []
    for gid in add_ids:
        if gid in seen_add_ids and gid not in duplicate_add_ids:
            duplicate_add_ids.append(gid)
        seen_add_ids.add(gid)
    if duplicate_add_ids:
        sys.stderr.write(
            f"gates.add[].id duplicated across merged layers: {duplicate_add_ids}\n"
        )
        emit_and_exit({
            "error": f"gates.add[].id duplicated across merged layers: {duplicate_add_ids}"
        }, 1)
    gates_directive = build_gates_directive(gates_cfg)
    gates_block_text = render_gates_block(gates_directive, inline_gate_ids)
    if gates_block_text:
        rendered = rendered.rstrip() + "\n" + gates_block_text

    # output_schema: declared structured-output contract. Inject a directive so
    # the skill returns exactly this JSON shape (standalone or composed in a
    # workflow use: node). It is a skill-level contract — keep it in base.yaml.
    output_schema = cfg.get("output_schema")
    if output_schema:
        rendered = rendered.rstrip() + (
            "\n\n## Output (required structured result)\n\n"
            "Return your final result as a single JSON object that validates against "
            "the schema below. Emit only that JSON object as your result — no prose, "
            "no commentary, no markdown fences around it:\n\n"
            "```json\n" + json.dumps(output_schema, indent=2) + "\n```\n"
        )

    context_block = ""
    context_cfg = cfg.get("context") or {}
    if context_cfg:
        result = build_context_block(context_cfg, skill_dir, vars_map, unresolved, warnings)
        if result is None:
            emit_and_exit({
                "skill_name": args.skill,
                "profile_used": profile_used,
                "profile_requested": args.profile,
                "warnings": warnings,
                "config": cfg,
            }, 1)
        context_block = result

    runtime_cfg = cfg.get("runtime") or {}
    directives = {
        "allowed_tools": runtime_cfg.get("allowed_tools") or [],
        "allowed_mcps": runtime_cfg.get("allowed_mcps") or [],
        "skip_steps": list(args.skip_step),
        "mandated_tools": {
            sk: sv["mandate_tool"]
            for sk, sv in (cfg.get("steps") or {}).items()
            if sv and "mandate_tool" in sv
        },
        "gates": gates_directive,
        # Workflow-composition executor identity: when set, a use: node runs this
        # microskill AS this agent on this model (compiler bakes them into agent()).
        "agent": runtime_cfg.get("agent"),
        "model": runtime_cfg.get("model"),
    }

    # Inputs declared `materialize: file` are large / multi-shape payloads passed BY
    # REFERENCE: when this microskill is invoked directly, the dispatcher normalizes the
    # caller-supplied string/file/dir into one canonical file and supplies only the short
    # path (the body reads it). Names only — the dispatcher does the filesystem work.
    materialize_inputs = sorted(
        name for name, spec in (cfg.get("inputs") or {}).items()
        if isinstance(spec, dict) and spec.get("materialize"))

    payload = {
        "skill_name": args.skill,
        "profile_used": profile_used,
        "profile_requested": args.profile,
        "warnings": warnings,
        "config": cfg,
        "rendered_skill_body": rendered,
        "unresolved_vars": unresolved,
        "injected_inputs": injected_inputs,
        "required_inputs": required_inputs,
        "materialize_inputs": materialize_inputs,
        "profile_overrides_inputs": profile_overrides_inputs,
        "context_block": context_block,
        "directives": directives,
        "output_schema": output_schema,
    }
    emit_and_exit(payload, 1 if inject_failed else 0)


if __name__ == "__main__":
    main()

# This repo is the plugin SOURCE. catalog/ is the committed source of truth; the
# runtime .claude/ is GENERATED (by initialize-harness + harness-sync) and gitignored —
# exactly like a consumer project. After cloning, run /initialize-harness (or
# `catalog/scripts/initialize-harness --apply --project-root . --catalog ./catalog`)
# to rebuild .claude/, then /sync-harness for any source:custom components in harness/.
.claude/
# Keep shared project settings trackable; local overrides stay ignored.
!.claude/settings.json

# OS cruft
.DS_Store

# Test runner cache
.pytest_cache/
__pycache__/
*.pyc

# Generated compile output (regenerated by compile-workflow)
**/.compiled/

# Transient sandbox/staging dirs (created at runtime by the create pipelines)
**/.staging/

# Node dev tooling (release automation only; the plugin ships no JS)
node_modules/
